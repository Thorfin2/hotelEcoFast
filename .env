###> PHPMailer ###
MAILER_HOST=smtp.hostinger.com
MAILER_PORT=465
MAILER_USERNAME=contact@ecofast-vtc.fr
# Mot de passe SMTP : en local, créer .env.local avec MAILER_PASSWORD=... (fichier ignoré par git).
# Sur Railway : définir la variable MAILER_PASSWORD dans Variables du service (elle remplace .env).
MAILER_PASSWORD=
MAILER_FROM_EMAIL=contact@ecofast-vtc.fr
MAILER_FROM_NAME="EcoFast VTC"
MAILER_ENCRYPTION=ssl
###< PHPMailer ###

