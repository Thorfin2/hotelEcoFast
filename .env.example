APP_ENV=dev
APP_SECRET=change_me_in_production

DATABASE_URL="mysql://user:password@127.0.0.1:3306/ecofasthotel?serverVersion=8.0&charset=utf8mb4"

# SMTP (Hostinger, Gmail, etc.)
MAILER_HOST=smtp.hostinger.com
MAILER_PORT=465
MAILER_USERNAME=contact@example.com
MAILER_PASSWORD=
MAILER_FROM_EMAIL=contact@example.com
MAILER_FROM_NAME="EcoFast Hotel"
MAILER_ENCRYPTION=ssl

# En local : copier ce fichier en .env.local et renseigner MAILER_PASSWORD (et autres secrets).
# Sur Railway : ajouter MAILER_PASSWORD, DATABASE_URL, APP_SECRET, etc. dans l’onglet Variables.
# Les variables du dashboard remplacent toujours les valeurs des fichiers .env.

APP_NAME="EcoFast Hotel"
APP_BASE_URL=http://localhost:8000
MAILER_ENABLED=true
SMS_SIMULATION=true
