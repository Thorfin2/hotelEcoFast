{% extends 'admin/base.html.twig' %}

{% block title %}Mon profil{% endblock %}
{% block page_title %}Mon profil{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">Modifiez vos informations personnelles et votre mot de passe</p>{% endblock %}

{% block content %}
<div class="max-w-2xl">

  {% for message in app.flashes('success') %}
    <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg flex items-center gap-2"
      x-data="{ show: true }" x-show="show" x-init="setTimeout(() => show = false, 4000)"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0">
      <span class="text-green-600 text-sm">&#10003;</span>
      <p class="text-green-800 text-sm">{{ message }}</p>
    </div>
  {% endfor %}

  <form method="post" class="space-y-6">

    <div class="card p-6">
      <h2 class="font-semibold text-dark-900 mb-4 flex items-center gap-2">
        <span class="w-7 h-7 bg-teal-100 text-teal-600 rounded-lg flex items-center justify-center text-sm">&#128100;</span>
        Informations personnelles
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="firstName" class="block text-sm font-semibold text-dark-700 mb-1.5">Pr&eacute;nom</label>
          <input type="text" name="firstName" id="firstName" value="{{ user.firstName }}" class="form-input" required>
        </div>
        <div>
          <label for="lastName" class="block text-sm font-semibold text-dark-700 mb-1.5">Nom</label>
          <input type="text" name="lastName" id="lastName" value="{{ user.lastName }}" class="form-input" required>
        </div>
      </div>
    </div>

    <div class="card p-6">
      <h2 class="font-semibold text-dark-900 mb-4 flex items-center gap-2">
        <span class="w-7 h-7 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center text-sm">&#9993;</span>
        Contact
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="email" class="block text-sm font-semibold text-dark-700 mb-1.5">Adresse email</label>
          <input type="email" name="email" id="email" value="{{ user.email }}" class="form-input" required>
          <p class="text-dark-400 text-xs mt-1.5">C'est cette adresse qui recevra les notifications admin</p>
        </div>
        <div>
          <label for="phone" class="block text-sm font-semibold text-dark-700 mb-1.5">T&eacute;l&eacute;phone</label>
          <input type="text" name="phone" id="phone" value="{{ user.phone }}" class="form-input" placeholder="06 00 00 00 00">
        </div>
      </div>
    </div>

    <div class="card p-6">
      <h2 class="font-semibold text-dark-900 mb-4 flex items-center gap-2">
        <span class="w-7 h-7 bg-amber-100 text-amber-600 rounded-lg flex items-center justify-center text-sm">&#128274;</span>
        Mot de passe
      </h2>
      <p class="text-dark-400 text-sm mb-4">Laissez vide pour ne pas modifier le mot de passe.</p>

      <div class="max-w-sm">
        <label for="newPassword" class="block text-sm font-semibold text-dark-700 mb-1.5">Nouveau mot de passe</label>
        <input type="password" name="newPassword" id="newPassword" class="form-input" placeholder="&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;" minlength="6">
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button type="submit" class="btn-primary py-2.5 px-6">
        Enregistrer les modifications
      </button>
      <a href="{{ path('admin_settings') }}" class="text-dark-400 text-sm hover:text-dark-600 transition">Annuler</a>
    </div>

  </form>
</div>
{% endblock %}
