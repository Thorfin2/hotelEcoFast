{% extends 'admin/base.html.twig' %}

{% block title %}Modifier {{ hotel.name }}{% endblock %}
{% block page_title %}Modifier l'hôtel{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">{{ hotel.name }} · ID #{{ hotel.id }}</p>{% endblock %}

{% block header_actions %}
  <a href="{{ path('admin_hotels') }}" class="btn-secondary">← Retour</a>
{% endblock %}

{% block content %}
<div class="max-w-2xl">
  {{ form_start(form) }}
  <div class="space-y-5">

    {# Infos générales #}
    <div class="card p-6">
      <h2 class="font-semibold text-dark-900 mb-4 text-sm flex items-center gap-2">
        <i class="fas fa-hotel text-dark-400"></i> Informations générales
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-dark-700 mb-1.5">{{ form_label(form.name) }}</label>
          {{ form_widget(form.name) }}
          {{ form_errors(form.name) }}
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-dark-700 mb-1.5">{{ form_label(form.address) }}</label>
          {{ form_widget(form.address) }}
        </div>
        <div>
          <label class="block text-sm font-medium text-dark-700 mb-1.5">{{ form_label(form.city) }}</label>
          {{ form_widget(form.city) }}
        </div>
        <div>
          <label class="block text-sm font-medium text-dark-700 mb-1.5">{{ form_label(form.stars) }}</label>
          {{ form_widget(form.stars) }}
        </div>
        <div>
          <label class="block text-sm font-medium text-dark-700 mb-1.5">{{ form_label(form.phone) }}</label>
          {{ form_widget(form.phone) }}
        </div>
        <div>
          <label class="block text-sm font-medium text-dark-700 mb-1.5">{{ form_label(form.email) }}</label>
          {{ form_widget(form.email) }}
        </div>
      </div>
    </div>

    {# Commission #}
    <div class="card p-6" x-data="{ enabled: {{ hotel.commissionEnabled ? 'true' : 'false' }} }">
      <h2 class="font-semibold text-dark-900 mb-4 text-sm flex items-center gap-2">
        <i class="fas fa-euro-sign text-dark-400"></i> Commission
      </h2>

      {# Toggle activer/désactiver #}
      <div class="flex items-center justify-between p-4 bg-dark-50 rounded-xl mb-4">
        <div>
          <div class="font-medium text-dark-800 text-sm">Activer les commissions</div>
          <div class="text-xs text-dark-400 mt-0.5">Si désactivé, l'onglet commissions sera masqué pour cet hôtel</div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          {{ form_widget(form.commissionEnabled, {'attr': {'x-model': 'enabled', 'class': 'sr-only peer'}}) }}
          <div class="w-11 h-6 bg-dark-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-gold-500"></div>
        </label>
      </div>

      {# Taux (visible seulement si commission activée) #}
      <div x-show="enabled" x-transition>
        <label class="block text-sm font-medium text-dark-700 mb-1.5">{{ form_label(form.commissionRate) }}</label>
        <div class="flex items-center gap-2">
          {{ form_widget(form.commissionRate, {'attr': {'class': 'form-input w-32'}}) }}
          <span class="text-dark-400 font-medium">%</span>
        </div>
        {{ form_errors(form.commissionRate) }}
      </div>
      <div x-show="!enabled" x-cloak class="text-sm text-dark-400 italic">
        <i class="fas fa-eye-slash mr-1"></i> Les commissions sont désactivées pour cet hôtel.
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button type="submit" class="btn-primary py-2.5 px-8">
        <i class="fas fa-floppy-disk mr-1.5"></i> Enregistrer les modifications
      </button>
      <a href="{{ path('admin_hotels') }}" class="btn-secondary">Annuler</a>
    </div>

  </div>
  {{ form_end(form) }}
</div>
{% endblock %}
