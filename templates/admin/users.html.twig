{% extends 'admin/base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}
{% block page_title %}Utilisateurs{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">{{ users|length }} utilisateur(s)</p>{% endblock %}

{% block header_actions %}
  <a href="{{ path('admin_user_new') }}" class="btn-primary">
    <i class="fas fa-user-plus mr-1.5"></i> Nouvel utilisateur
  </a>
{% endblock %}

{% block content %}
<div class="card overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="bg-dark-50 border-b border-dark-100">
        <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase">Utilisateur</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase">Email</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase">Rôle</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase">Profil associé</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase">Statut</th>
        <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase">Créé le</th>
        <th class="text-center px-5 py-3 text-xs font-semibold text-dark-400 uppercase">Action</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-dark-50">
      {% for user in users %}
        <tr class="hover:bg-gold-50/50 transition-colors">
          <td class="px-5 py-3.5">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold
                {% if 'ROLE_ADMIN' in user.roles %}bg-navy-700
                {% elseif 'ROLE_HOTEL' in user.roles %}bg-amber-500
                {% else %}bg-blue-500{% endif %}">
                {{ user.firstName|first }}{{ user.lastName|first }}
              </div>
              <span class="font-semibold font-display text-dark-900 text-sm">{{ user.fullName }}</span>
            </div>
          </td>
          <td class="px-5 py-3.5 text-sm text-dark-500">{{ user.email }}</td>
          <td class="px-5 py-3.5">
            {% if 'ROLE_ADMIN' in user.roles %}
              <span class="badge bg-navy-100 text-navy-800"><i class="fas fa-shield-halved mr-1"></i>Admin</span>
            {% elseif 'ROLE_HOTEL' in user.roles %}
              <span class="badge bg-amber-100 text-amber-800"><i class="fas fa-hotel mr-1"></i>Hôtel</span>
            {% elseif 'ROLE_DRIVER' in user.roles %}
              <span class="badge bg-blue-100 text-blue-800"><i class="fas fa-car mr-1"></i>Chauffeur</span>
            {% else %}
              <span class="badge bg-gray-100 text-gray-800">Utilisateur</span>
            {% endif %}
          </td>
          <td class="px-5 py-3.5 text-sm text-dark-500">
            {% if user.hotel %}<i class="fas fa-hotel text-dark-300 mr-1"></i>{{ user.hotel.name }}
            {% elseif user.driver %}<i class="fas fa-car text-dark-300 mr-1"></i>{{ user.driver.vehicleModel }}
            {% else %}—{% endif %}
          </td>
          <td class="px-5 py-3.5">
            <span class="badge {{ user.isActive ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' }}">
              {{ user.isActive ? 'Actif' : 'Inactif' }}
            </span>
          </td>
          <td class="px-5 py-3.5 text-xs text-dark-300">{{ user.createdAt|date('d/m/Y') }}</td>
          <td class="px-5 py-3.5 text-center">
            {% if app.user.id != user.id %}
              <form method="post"
                    action="{{ path('admin_user_delete', {id: user.id}) }}"
                    x-data
                    @submit.prevent="if(confirm('Supprimer « {{ user.fullName }} » ?\nCette action est irréversible.')) $el.submit()">
                <button type="submit"
                  class="w-8 h-8 rounded-lg bg-red-50 text-red-500 hover:bg-red-100 hover:text-red-700 transition-all duration-200 flex items-center justify-center mx-auto"
                  title="Supprimer ce compte">
                  <i class="fas fa-trash-can text-xs"></i>
                </button>
              </form>
            {% else %}
              <span class="text-dark-200 text-xs" title="Votre propre compte"><i class="fas fa-lock"></i></span>
            {% endif %}
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
