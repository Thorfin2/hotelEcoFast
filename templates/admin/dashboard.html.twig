{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">Vue d'ensemble · {{ 'now'|date('d/m/Y H:i') }}</p>{% endblock %}

{% block content %}
{# Stats with animated counters #}
<div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-6 stagger-in">
  <div class="card p-4 group" x-data="counter({{ stats.total }})" x-init="start()">
    <div class="text-xs font-semibold text-dark-400 uppercase tracking-wider mb-2">Total</div>
    <div class="text-3xl font-bold text-dark-900 transition-transform duration-300 group-hover:scale-105" x-text="current"></div>
    <div class="text-xs text-dark-300 mt-1">courses</div>
  </div>
  <div class="card p-4 border-amber-100 group" x-data="counter({{ stats.pending }})" x-init="start()">
    <div class="text-xs font-semibold text-amber-600 uppercase tracking-wider mb-2">En attente</div>
    <div class="text-3xl font-bold text-amber-600" x-text="current"></div>
    <div class="text-xs text-amber-400 mt-1">à assigner</div>
    {% if stats.pending > 0 %}
      <div class="mt-2 flex items-center gap-1 text-xs text-amber-600 font-medium">
        <span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></span> Action requise
      </div>
    {% endif %}
  </div>
  <div class="card p-4 border-blue-100 group" x-data="counter({{ stats.active }})" x-init="start()">
    <div class="text-xs font-semibold text-blue-600 uppercase tracking-wider mb-2">Actives</div>
    <div class="text-3xl font-bold text-blue-600" x-text="current"></div>
    <div class="text-xs text-blue-400 mt-1">en cours</div>
  </div>
  <div class="card p-4 border-green-100 group" x-data="counter({{ stats.completed }})" x-init="start()">
    <div class="text-xs font-semibold text-green-600 uppercase tracking-wider mb-2">Terminées</div>
    <div class="text-3xl font-bold text-green-600" x-text="current"></div>
    <div class="text-xs text-green-400 mt-1">avec succès</div>
  </div>
  <div class="card p-4 group animate-glow-pulse" style="background:linear-gradient(135deg,rgba(90,184,46,0.07),#fff);border-color:#d4f0b8"
    x-data="counter({{ stats.revenue }}, true)" x-init="start()">
    <div class="text-xs font-semibold text-eco-600 uppercase tracking-wider mb-2">CA Total</div>
    <div class="text-2xl font-bold text-eco-700"><span x-text="current"></span> €</div>
    <div class="text-xs text-eco-400 mt-1">revenus</div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  {# Pending rides — ALERT #}
  <div class="lg:col-span-2">
    {% if pendingRides is not empty %}
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-4 animate-fade-in">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></span>
          <h2 class="font-bold text-amber-800">{{ pendingRides|length }} course(s) sans chauffeur</h2>
        </div>
        <div class="space-y-2 stagger-in">
          {% for ride in pendingRides|slice(0, 3) %}
            <div class="flex items-center justify-between bg-white rounded-lg px-4 py-3 shadow-sm transition-all duration-300 hover:shadow-md hover:translate-x-1">
              <div>
                <span class="font-mono text-xs text-dark-400">{{ ride.reference }}</span>
                <span class="mx-2 text-dark-200">·</span>
                <span class="font-semibold text-dark-900 text-sm">{{ ride.clientName }}</span>
                <span class="mx-2 text-dark-200">·</span>
                <span class="text-xs text-dark-400">{{ ride.hotel.name }}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs text-dark-300">{{ ride.pickupDatetime|date('d/m H:i') }}</span>
                <a href="{{ path('admin_assign_driver', {id: ride.id}) }}"
                   class="btn-primary text-xs py-1.5 px-3">Assigner →</a>
              </div>
            </div>
          {% endfor %}
          {% if pendingRides|length > 3 %}
            <a href="{{ path('admin_rides', {status: 'pending'}) }}" class="text-amber-700 text-sm font-medium hover:underline transition-all duration-200 hover:translate-x-1 inline-block">
              + {{ pendingRides|length - 3 }} autres courses en attente
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {# Upcoming rides #}
    <div class="card overflow-hidden">
      <div class="flex items-center justify-between p-5 border-b border-gray-50">
        <h2 class="font-semibold text-dark-900 font-display">Courses à venir</h2>
        <a href="{{ path('admin_rides') }}" class="text-gold-600 text-sm font-medium hover:underline transition-all duration-200 hover:translate-x-1 inline-block">Voir tout →</a>
      </div>
      {% if upcomingRides is empty %}
        <div class="p-8 text-center text-dark-300 text-sm">Aucune course à venir</div>
      {% else %}
        <div class="divide-y divide-gray-50 stagger-in">
          {% for ride in upcomingRides %}
            <div class="flex items-center gap-4 px-5 py-3.5 hover:bg-gold-50/50 transition-all duration-300 hover:pl-7 group">
              <div class="text-2xl transition-transform duration-300 group-hover:scale-110">{{ ride.statusIcon }}</div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-semibold text-dark-900">{{ ride.clientName }}</span>
                  <span class="font-mono text-xs text-dark-300">{{ ride.reference }}</span>
                </div>
                <div class="text-xs text-dark-300 truncate">{{ ride.hotel.name }} · {{ ride.pickupAddress|split(',')|first }}</div>
              </div>
              <div class="text-right">
                <div class="text-xs font-medium text-dark-600">{{ ride.pickupDatetime|date('d/m H:i') }}</div>
                {% if ride.driver %}
                  <div class="text-xs text-dark-300">{{ ride.driver.fullName }}</div>
                {% else %}
                  <a href="{{ path('admin_assign_driver', {id: ride.id}) }}" class="text-xs text-amber-600 font-medium hover:underline">Assigner →</a>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>

  {# Right sidebar #}
  <div class="space-y-4 stagger-in">
    {# Available drivers #}
    <div class="card p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-dark-900 font-display">Chauffeurs disponibles</h2>
        <span class="badge bg-green-100 text-green-800">{{ availableDrivers|length }}</span>
      </div>
      {% if availableDrivers is empty %}
        <p class="text-dark-300 text-sm">Aucun chauffeur disponible</p>
      {% else %}
        <div class="space-y-2">
          {% for driver in availableDrivers|slice(0, 5) %}
            <div class="flex items-center gap-2.5 group transition-all duration-200 hover:translate-x-1">
              <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-700 text-xs font-bold transition-all duration-300 group-hover:bg-green-200 group-hover:scale-110">
                {{ driver.firstName|first }}{{ driver.lastName|first }}
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-dark-900 truncate">{{ driver.fullName }}</div>
                <div class="text-xs text-dark-300">{{ driver.vehicleModel }}</div>
              </div>
              <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
      <a href="{{ path('admin_drivers') }}" class="text-gold-600 text-xs font-medium hover:underline mt-3 block transition-all duration-200 hover:translate-x-1">Gérer les chauffeurs →</a>
    </div>

    {# Recent notifications #}
    <div class="card p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-dark-900 font-display">Dernières notifications</h2>
        <a href="{{ path('admin_notifications') }}" class="text-xs text-gold-600 hover:underline">Tout voir</a>
      </div>
      {% if recentNotifications is empty %}
        <p class="text-dark-300 text-sm">Aucune notification</p>
      {% else %}
        <div class="space-y-2">
          {% for notif in recentNotifications %}
            <div class="flex items-center gap-2.5 py-1.5 border-b border-gray-50 last:border-0 transition-all duration-200 hover:translate-x-1">
              <span class="text-base">{{ notif.channel == 'email' ? '<i class="fas fa-envelope"></i>'|raw : '<i class="fas fa-comment-dots"></i>'|raw }}</span>
              <div class="flex-1 min-w-0">
                <div class="text-xs font-medium text-dark-900 truncate">{{ notif.typeLabel }}</div>
                <div class="text-xs text-dark-300">→ {{ notif.recipientLabel }} · {{ notif.createdAt|date('H:i') }}</div>
              </div>
              <div class="w-1.5 h-1.5 rounded-full {{ notif.status == 'sent' ? 'bg-green-500' : 'bg-red-500' }}"></div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function counter(target, isDecimal = false) {
  return {
    current: 0,
    target: target,
    start() {
      if (this.target === 0) return;
      const duration = 1200;
      const steps = 40;
      let step = 0;
      const timer = setInterval(() => {
        step++;
        const progress = step / steps;
        const eased = 1 - Math.pow(1 - progress, 3);
        this.current = isDecimal
          ? Math.round(this.target * eased).toLocaleString('fr-FR')
          : Math.round(this.target * eased);
        if (step >= steps) {
          this.current = isDecimal
            ? Math.round(this.target).toLocaleString('fr-FR')
            : this.target;
          clearInterval(timer);
        }
      }, duration / steps);
    }
  }
}
</script>
{% endblock %}
