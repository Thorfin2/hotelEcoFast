{% extends 'layout/app.html.twig' %}

{% block nav_links %}
  <a href="{{ path('admin_dashboard') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Dashboard
  </a>
  <a href="{{ path('admin_rides') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') starts with 'admin_ride' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Courses
  </a>
  <a href="{{ path('admin_hotels') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') starts with 'admin_hotel' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Hôtels
  </a>
  <a href="{{ path('admin_drivers') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') starts with 'admin_driver' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Chauffeurs
  </a>
  <a href="{{ path('admin_users') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') starts with 'admin_user' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Utilisateurs
  </a>
  <a href="{{ path('admin_commissions') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') == 'admin_commissions' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Commissions
  </a>
  <a href="{{ path('admin_notifications') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') == 'admin_notifications' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Notifications
  </a>
  <a href="{{ path('admin_settings') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') == 'admin_settings' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Paramètres
  </a>
{% endblock %}

{% block mobile_nav %}
  <a href="{{ path('admin_dashboard') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Dashboard</a>
  <a href="{{ path('admin_rides') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') starts with 'admin_ride' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Courses</a>
  <a href="{{ path('admin_hotels') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') starts with 'admin_hotel' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Hôtels</a>
  <a href="{{ path('admin_drivers') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') starts with 'admin_driver' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Chauffeurs</a>
  <a href="{{ path('admin_users') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') starts with 'admin_user' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Utilisateurs</a>
  <a href="{{ path('admin_commissions') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') == 'admin_commissions' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Commissions</a>
  <a href="{{ path('admin_notifications') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') == 'admin_notifications' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Notifications</a>
  <a href="{{ path('admin_settings') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') == 'admin_settings' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Paramètres</a>
{% endblock %}
