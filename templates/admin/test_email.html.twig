{% extends 'admin/base.html.twig' %}

{% block title %}Test email SMTP{% endblock %}
{% block page_title %}Test email (Symfony Mailer){% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">Même configuration <code class="text-xs">MAILER_*</code> que les notifications.</p>{% endblock %}

{% block content %}
<div class="max-w-lg">
  <form method="post" class="card p-6 space-y-4">
    <div>
      <label for="to" class="block text-sm font-semibold text-dark-700 mb-1">Destinataire</label>
      <input type="email" id="to" name="to" value="{{ to }}" required
        class="form-input" placeholder="exemple@gmail.com">
    </div>
    <button type="submit" class="btn-gold w-full justify-center py-3">
      Envoyer le test
    </button>
  </form>

  {% if sent %}
    <div class="mt-6 rounded-lg border border-green-200 bg-green-50 text-green-800 px-4 py-3 text-sm">
      Email envoyé. Vérifie la boîte de réception (et les spams).
    </div>
  {% elseif error %}
    <div class="mt-6 rounded-lg border border-red-200 bg-red-50 text-red-800 px-4 py-3 text-sm">
      <strong>Erreur :</strong> {{ error }}
    </div>
  {% endif %}

  {% if transport_debug %}
    <pre class="mt-4 text-xs bg-dark-900 text-dark-300 p-4 rounded-lg overflow-auto max-h-64 whitespace-pre-wrap">{{ transport_debug }}</pre>
  {% endif %}

  <div class="mt-8 card p-4 text-xs text-dark-600 space-y-1">
    <p class="font-semibold text-dark-800">Configuration lue par l’app</p>
    <p>MAILER_ENABLED : {{ mailer_enabled ? 'oui' : 'non' }}</p>
    <p>Host : {{ mailer_host }} — Port : {{ mailer_port }} — Encryption : {{ mailer_encryption }}</p>
    <p>Username : {{ mailer_username }}</p>
    <p>Password : {% if mailer_password_configured %}présent{% else %}<span class="text-red-600 font-medium">absent</span> (Railway ou .env.local){% endif %}</p>
    <p>From : {{ mailer_from_email }}</p>
  </div>
</div>
{% endblock %}
