{% extends 'admin/base.html.twig' %}

{% block title %}Modifier {{ driver.fullName }}{% endblock %}
{% block page_title %}Modifier le chauffeur{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">{{ driver.fullName }}</p>{% endblock %}

{% block header_actions %}
  <a href="{{ path('admin_drivers') }}" class="btn-secondary">← Retour</a>
{% endblock %}

{% block content %}
<div class="max-w-2xl">
  <div class="card p-6">
    {{ form_start(form) }}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {% for field in form %}
        <div>
          <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(field) }}</label>
          {{ form_widget(field) }}
          {{ form_errors(field) }}
        </div>
      {% endfor %}
    </div>
    <button type="submit" class="btn-primary mt-4">Enregistrer</button>
    {{ form_end(form) }}
  </div>
</div>
{% endblock %}
