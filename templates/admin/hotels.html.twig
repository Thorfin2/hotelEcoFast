{% extends 'admin/base.html.twig' %}

{% block title %}Hôtels partenaires{% endblock %}
{% block page_title %}Hôtels partenaires{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">{{ hotels|length }} hôtel(s)</p>{% endblock %}

{% block header_actions %}
  <a href="{{ path('admin_user_new') }}" class="btn-primary">+ Nouvel hôtel</a>
{% endblock %}

{% block content %}
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 stagger-in">
  {% for hotel in hotels %}
    <div class="card p-5 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 group {{ not hotel.isActive ? 'opacity-60' : '' }}">
      <div class="flex items-start justify-between mb-3">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gold-50 rounded-xl flex items-center justify-center text-2xl"><i class="fas fa-hotel"></i></div>
          <div>
            <h3 class="font-bold font-display text-dark-900">{{ hotel.name }}</h3>
            <p class="text-dark-300 text-xs">{{ hotel.stars ? hotel.stars ~ ' ⭐' : '' }} {{ hotel.city }}</p>
          </div>
        </div>
        <span class="badge {{ hotel.isActive ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-dark-400' }}">
          {{ hotel.isActive ? 'Actif' : 'Inactif' }}
        </span>
      </div>

      <div class="space-y-1.5 text-xs text-dark-400 mb-4">
        <div class="flex items-center gap-1.5"><i class="fas fa-location-dot"></i>{{ hotel.address }}, {{ hotel.city }}</div>
        {% if hotel.phone %}<div class="flex items-center gap-1.5"><i class="fas fa-phone"></i>{{ hotel.phone }}</div>{% endif %}
        {% if hotel.email %}<div class="flex items-center gap-1.5"><i class="fas fa-envelope"></i>{{ hotel.email }}</div>{% endif %}
      </div>

      <div class="flex items-center justify-between pt-3 border-t border-dark-100">
        <div class="text-center">
          <div class="text-lg font-bold text-gold-700">{{ hotel.commissionRate }}%</div>
          <div class="text-xs text-dark-300">Commission</div>
        </div>
        <div class="text-center">
          <div class="text-lg font-bold text-dark-900">{{ hotel.rides|length }}</div>
          <div class="text-xs text-dark-300">Courses</div>
        </div>
        <div class="flex gap-2">
          <a href="{{ path('admin_hotel_edit', {id: hotel.id}) }}" class="text-xs text-gold-600 hover:underline font-medium">Modifier</a>
          <form method="post" action="{{ path('admin_hotel_toggle', {id: hotel.id}) }}" class="inline">
            <button class="text-xs {{ hotel.isActive ? 'text-red-500' : 'text-green-600' }} hover:underline font-medium">
              {{ hotel.isActive ? 'Désactiver' : 'Activer' }}
            </button>
          </form>
        </div>
      </div>
    </div>
  {% else %}
    <div class="col-span-3 card p-12 text-center">
      <div class="text-5xl mb-4"><i class="fas fa-hotel"></i></div>
      <p class="text-dark-400">Aucun hôtel partenaire</p>
      <a href="{{ path('admin_user_new') }}" class="btn-primary mt-4 inline-flex">Ajouter un hôtel</a>
    </div>
  {% endfor %}
</div>
{% endblock %}
