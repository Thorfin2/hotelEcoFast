{% extends 'admin/base.html.twig' %}

{% block title %}Course #{{ ride.reference }}{% endblock %}
{% block page_title %}Course #{{ ride.reference }}{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">{{ ride.hotel.name }} · {{ ride.clientName }}</p>{% endblock %}

{% block header_actions %}
  <a href="{{ path('admin_rides') }}" class="btn-secondary">← Retour</a>
  {% if ride.status in ['pending', 'assigned'] %}
    <a href="{{ path('admin_assign_driver', {id: ride.id}) }}" class="btn-primary">👤 Assigner chauffeur</a>
  {% endif %}
{% endblock %}

{% block content %}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">

    {# Status + actions #}
    <div class="card p-5">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="text-3xl">{{ ride.statusIcon }}</div>
          <div>
            <div class="font-display font-bold text-dark-900">{{ ride.statusLabel }}</div>
            <div class="text-sm text-dark-400">{{ ride.reference }}</div>
          </div>
        </div>
        <div class="flex gap-2 flex-wrap" x-data>
          {% if ride.status == 'assigned' %}
            <form method="post" action="{{ path('admin_update_ride_status', {id: ride.id, status: 'in_progress'}) }}">
              <button class="btn-primary text-xs py-1.5">🚗 Démarrer</button>
            </form>
          {% elseif ride.status == 'confirmed' %}
            <form method="post" action="{{ path('admin_update_ride_status', {id: ride.id, status: 'in_progress'}) }}">
              <button class="btn-primary text-xs py-1.5">🚗 Démarrer la course</button>
            </form>
          {% elseif ride.status == 'in_progress' %}
            <form method="post" action="{{ path('admin_update_ride_status', {id: ride.id, status: 'completed'}) }}">
              <button class="btn-primary text-xs py-1.5" style="background:#059669">🏁 Terminer la course</button>
            </form>
          {% endif %}
          {% if ride.status not in ['completed', 'cancelled'] %}
            <form method="post" action="{{ path('admin_update_ride_status', {id: ride.id, status: 'cancelled'}) }}"
                  @submit.prevent="if(confirm('Confirmer l\'annulation ?')) $el.submit()">
              <button class="btn-danger text-xs py-1.5">❌ Annuler</button>
            </form>
          {% endif %}
        </div>
      </div>
    </div>

    {# Details #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="card p-5">
        <h3 class="font-display font-semibold text-dark-900 mb-3 text-sm">👤 Client</h3>
        <dl class="space-y-2 text-sm">
          <div><dt class="text-dark-300 text-xs">Nom</dt><dd class="font-semibold">{{ ride.clientName }}</dd></div>
          {% if ride.clientPhone %}<div><dt class="text-dark-300 text-xs">Tél</dt><dd><a href="tel:{{ ride.clientPhone }}" class="text-gold-600">{{ ride.clientPhone }}</a></dd></div>{% endif %}
          {% if ride.clientEmail %}<div><dt class="text-dark-300 text-xs">Email</dt><dd class="truncate">{{ ride.clientEmail }}</dd></div>{% endif %}
          <div><dt class="text-dark-300 text-xs">Passagers</dt><dd>{{ ride.passengers }}</dd></div>
          {% if ride.luggage %}<div><dt class="text-dark-300 text-xs">Bagages</dt><dd>{{ ride.luggage }}</dd></div>{% endif %}
          {% if ride.flightNumber %}<div><dt class="text-dark-300 text-xs">Vol</dt><dd>✈️ {{ ride.flightNumber }}</dd></div>{% endif %}
        </dl>
      </div>
      <div class="card p-5">
        <h3 class="font-display font-semibold text-dark-900 mb-3 text-sm">🏨 Hôtel</h3>
        <dl class="space-y-2 text-sm">
          <div><dt class="text-dark-300 text-xs">Nom</dt><dd class="font-semibold">{{ ride.hotel.name }}</dd></div>
          <div><dt class="text-dark-300 text-xs">Ville</dt><dd>{{ ride.hotel.city }}</dd></div>
          <div><dt class="text-dark-300 text-xs">Commission</dt><dd class="text-gold-700 font-bold">{{ ride.hotel.commissionRate }}%</dd></div>
        </dl>
      </div>
    </div>

    <div class="card p-5">
      <h3 class="font-display font-semibold text-dark-900 mb-3 text-sm">🚗 Trajet</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div><dt class="text-dark-300 text-xs">Départ</dt><dd class="font-medium mt-0.5">{{ ride.pickupAddress }}</dd></div>
        <div><dt class="text-dark-300 text-xs">Destination</dt><dd class="font-medium mt-0.5">{{ ride.destinationAddress }}</dd></div>
        <div><dt class="text-dark-300 text-xs">Date & Heure</dt><dd class="font-bold text-gold-700 mt-0.5">{{ ride.pickupDatetime|date('d/m/Y à H:i') }}</dd></div>
        {% if ride.rideType %}<div><dt class="text-dark-300 text-xs">Type</dt><dd class="mt-0.5">{{ ride.rideType }}</dd></div>{% endif %}
      </div>
      {% if ride.notes %}
        <div class="mt-3 pt-3 border-t border-gray-100">
          <dt class="text-dark-300 text-xs mb-1">Notes</dt>
          <dd class="text-sm text-dark-600 bg-amber-50 rounded-lg p-3">{{ ride.notes }}</dd>
        </div>
      {% endif %}
    </div>

    {# Notifications #}
    {% if ride.notifications is not empty %}
    <div class="card p-5">
      <h3 class="font-display font-semibold text-dark-900 mb-3 text-sm">📬 Historique notifications</h3>
      <div class="space-y-2">
        {% for notif in ride.notifications %}
          <div class="flex items-center gap-3 py-2 border-b border-gray-50 last:border-0">
            <span class="text-lg">{{ notif.channel == 'email' ? '✉️' : '💬' }}</span>
            <div class="flex-1">
              <div class="text-xs font-medium text-dark-900">{{ notif.typeLabel }} → {{ notif.recipientLabel }}</div>
              <div class="text-xs text-dark-300">{{ notif.recipientEmail ?? notif.recipientPhone }} · {{ notif.createdAt|date('d/m H:i') }}</div>
            </div>
            <span class="badge {{ notif.status == 'sent' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' }}">
              {{ notif.status == 'sent' ? 'Envoyé' : 'Échec' }}
            </span>
          </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>

  {# Sidebar #}
  <div class="space-y-4">
    {# Driver #}
    {% if ride.driver %}
    <div class="card p-5">
      <h3 class="font-display font-semibold text-dark-900 mb-3 text-sm">🚘 Chauffeur</h3>
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 bg-gold-100 rounded-full flex items-center justify-center text-gold-700 font-bold">
          {{ ride.driver.firstName|first }}{{ ride.driver.lastName|first }}
        </div>
        <div>
          <div class="font-display font-semibold text-dark-900">{{ ride.driver.fullName }}</div>
          <div class="text-xs text-dark-400">{{ ride.driver.vehicleModel }}</div>
        </div>
      </div>
      <div class="space-y-1.5 text-xs text-dark-500">
        <div>📞 <a href="tel:{{ ride.driver.phone }}" class="text-gold-600">{{ ride.driver.phone }}</a></div>
        <div>🔑 <span class="font-mono bg-dark-100 px-1.5 py-0.5 rounded">{{ ride.driver.licensePlate }}</span></div>
      </div>
      {% if ride.status in ['pending', 'assigned'] %}
        <a href="{{ path('admin_assign_driver', {id: ride.id}) }}" class="btn-secondary text-xs mt-3 inline-flex">Changer le chauffeur</a>
      {% endif %}
    </div>
    {% else %}
    <div class="card p-5 border-amber-100 bg-amber-50">
      <h3 class="font-semibold text-amber-800 mb-2 text-sm">🚘 Aucun chauffeur</h3>
      <p class="text-amber-600 text-xs mb-3">Cette course nécessite l'assignation d'un chauffeur.</p>
      <a href="{{ path('admin_assign_driver', {id: ride.id}) }}" class="btn-primary text-sm">Assigner maintenant →</a>
    </div>
    {% endif %}

    {# Financials #}
    {% if ride.price %}
    <div class="card p-5">
      <h3 class="font-display font-semibold text-dark-900 mb-3 text-sm">💰 Financier</h3>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between"><span class="text-dark-400">Prix total</span><span class="font-bold">{{ ride.price }} €</span></div>
        <div class="flex justify-between pt-1.5 border-t border-gray-100"><span class="text-dark-400">Commission hôtel</span><span class="font-bold text-gold-700">{{ ride.hotelCommission }} €</span></div>
        {% if ride.driverAmount %}<div class="flex justify-between"><span class="text-dark-400">Part chauffeur</span><span class="font-medium">{{ ride.driverAmount }} €</span></div>{% endif %}
      </div>
    </div>
    {% endif %}

    {# Timeline #}
    <div class="card p-5">
      <h3 class="font-display font-semibold text-dark-900 mb-3 text-sm">📅 Chronologie</h3>
      <div class="space-y-2.5 text-xs">
        <div class="flex gap-2 text-dark-500"><div class="w-2 h-2 rounded-full bg-gold-500 mt-1 flex-shrink-0"></div><div><span class="font-medium">Créée :</span> {{ ride.createdAt|date('d/m/Y H:i') }}</div></div>
        {% if ride.assignedAt %}<div class="flex gap-2 text-dark-500"><div class="w-2 h-2 rounded-full bg-blue-500 mt-1 flex-shrink-0"></div><div><span class="font-medium">Assignée :</span> {{ ride.assignedAt|date('d/m/Y H:i') }}</div></div>{% endif %}
        {% if ride.startedAt %}<div class="flex gap-2 text-dark-500"><div class="w-2 h-2 rounded-full bg-purple-500 mt-1 flex-shrink-0"></div><div><span class="font-medium">Démarrée :</span> {{ ride.startedAt|date('d/m/Y H:i') }}</div></div>{% endif %}
        {% if ride.completedAt %}<div class="flex gap-2 text-dark-500"><div class="w-2 h-2 rounded-full bg-green-500 mt-1 flex-shrink-0"></div><div><span class="font-medium">Terminée :</span> {{ ride.completedAt|date('d/m/Y H:i') }}</div></div>{% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
