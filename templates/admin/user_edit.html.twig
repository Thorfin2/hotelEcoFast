{% extends 'admin/base.html.twig' %}

{% block title %}Modifier {{ user.fullName }}{% endblock %}
{% block page_title %}Modifier l'utilisateur{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">{{ user.email }}</p>{% endblock %}

{% block header_actions %}
  <a href="{{ path('admin_users') }}" class="btn-secondary">← Retour</a>
{% endblock %}

{% block content %}
<div class="max-w-lg space-y-6">

  {% if error %}
    <div class="p-4 bg-red-50 border border-red-200 rounded-xl flex items-center gap-2 text-sm text-red-700">
      <i class="fas fa-triangle-exclamation text-red-500"></i> {{ error }}
    </div>
  {% endif %}

  <form method="post" class="space-y-5">

    {# Identité #}
    <div class="card p-6">
      <h2 class="font-semibold text-dark-900 mb-4 text-sm flex items-center gap-2">
        <i class="fas fa-user text-dark-400"></i> Identité
      </h2>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-dark-700 mb-1.5">Prénom</label>
          <input type="text" name="firstName" value="{{ user.firstName }}" required class="form-input">
        </div>
        <div>
          <label class="block text-sm font-medium text-dark-700 mb-1.5">Nom</label>
          <input type="text" name="lastName" value="{{ user.lastName }}" required class="form-input">
        </div>
        <div class="col-span-2">
          <label class="block text-sm font-medium text-dark-700 mb-1.5">Email</label>
          <input type="email" name="email" value="{{ user.email }}" required class="form-input">
        </div>
        <div class="col-span-2">
          <label class="block text-sm font-medium text-dark-700 mb-1.5">Téléphone</label>
          <input type="tel" name="phone" value="{{ user.phone }}" class="form-input">
        </div>
      </div>
    </div>

    {# Rôle #}
    {% set currentRole = user.roles|filter(r => r != 'ROLE_USER')|first %}
    <div class="card p-6" x-data="{ role: '{{ currentRole }}' }">
      <h2 class="font-semibold text-dark-900 mb-4 text-sm flex items-center gap-2">
        <i class="fas fa-shield-halved text-dark-400"></i> Rôle
      </h2>
      <div class="space-y-2">
        {% for label, value in {
          'Administrateur': 'ROLE_ADMIN',
          'Hôtel — Admin complet': 'ROLE_HOTEL',
          'Hôtel — Employé (création de course uniquement)': 'ROLE_HOTEL_EMPLOYEE',
          'Chauffeur': 'ROLE_DRIVER'
        } %}
          <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-colors
            {{ currentRole == value ? 'border-gold-400 bg-gold-50' : 'border-dark-100 hover:bg-dark-50' }}">
            <input type="radio" name="role" value="{{ value }}"
              {{ currentRole == value ? 'checked' : '' }}
              x-model="role"
              class="text-gold-500 focus:ring-gold-400">
            <span class="text-sm font-medium text-dark-800">{{ label }}</span>
          </label>
        {% endfor %}
      </div>

      {# Sélecteur d'hôtel pour les employés #}
      <div x-show="role === 'ROLE_HOTEL_EMPLOYEE'" x-cloak class="mt-4 pt-4 border-t border-dark-100">
        <label class="block text-sm font-medium text-dark-700 mb-1.5">
          <i class="fas fa-hotel mr-1 text-amber-500"></i> Hôtel d'affectation
        </label>
        <select name="hotel_assignment" class="form-select">
          <option value="">— Aucun —</option>
          {% for hotel in hotels %}
            <option value="{{ hotel.id }}"
              {{ user.hotelAssignment and user.hotelAssignment.id == hotel.id ? 'selected' : '' }}>
              {{ hotel.name }} ({{ hotel.city }})
            </option>
          {% endfor %}
        </select>
        <p class="text-xs text-dark-400 mt-1">L'employé créera des courses pour cet hôtel.</p>
      </div>

      {% if app.user.id == user.id %}
        <p class="text-xs text-amber-600 mt-3"><i class="fas fa-triangle-exclamation mr-1"></i>Vous modifiez votre propre compte — changer votre rôle vous déconnectera.</p>
      {% endif %}
    </div>

    {# Mot de passe #}
    <div class="card p-6">
      <h2 class="font-semibold text-dark-900 mb-4 text-sm flex items-center gap-2">
        <i class="fas fa-lock text-dark-400"></i> Réinitialiser le mot de passe
      </h2>
      <p class="text-dark-400 text-xs mb-3">Laissez vide pour conserver le mot de passe actuel.</p>
      <div x-data="{ show: false }">
        <div class="relative">
          <input :type="show ? 'text' : 'password'" name="newPassword"
            placeholder="Nouveau mot de passe (min. 8 caractères)"
            class="form-input pr-10">
          <button type="button" @click="show=!show"
            class="absolute right-3 top-1/2 -translate-y-1/2 text-dark-400 hover:text-dark-600">
            <i :class="show ? 'fas fa-eye-slash' : 'fas fa-eye'" class="text-sm"></i>
          </button>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button type="submit" class="btn-primary py-2.5 px-8">
        <i class="fas fa-floppy-disk mr-1.5"></i> Enregistrer les modifications
      </button>
      <a href="{{ path('admin_users') }}" class="btn-secondary">Annuler</a>
    </div>

  </form>
</div>
{% endblock %}
