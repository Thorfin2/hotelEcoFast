{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col sm:justify-center items-center pt-6 sm:pt-0 bg-navy-950">

  {# Logo #}
  <div class="mb-6 text-center" x-data="{ show: false }" x-init="setTimeout(() => show = true, 100)" x-show="show"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 -translate-y-4"
    x-transition:enter-end="opacity-100 translate-y-0">
    <div class="inline-flex flex-col items-center gap-2 mb-3">
      <img src="/images/logo.png" alt="EcoFast VTC" class="h-20 w-auto">
    </div>
    <p class="text-white/50 text-sm">Plateforme de gestion de transport hôtelier</p>
  </div>

  {# Login card #}
  <div class="w-full sm:max-w-md px-6 py-6 bg-white shadow-xl overflow-hidden sm:rounded-xl"
    x-data="{ show: false }" x-init="setTimeout(() => show = true, 200)" x-show="show"
    x-transition:enter="transition ease-out duration-400"
    x-transition:enter-start="opacity-0 translate-y-4"
    x-transition:enter-end="opacity-100 translate-y-0">

    <h1 class="text-lg font-bold text-navy-900 mb-5">Connexion</h1>

    {% if error %}
      <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-md flex items-center gap-2 animate-fade-in">
        <i class="fas fa-triangle-exclamation text-red-500"></i>
        <p class="text-red-700 text-sm">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
      </div>
    {% endif %}

    <form method="post" class="space-y-4" action="{{ path('app_login') }}">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

      <div>
        <label class="block text-sm font-medium text-dark-700 mb-1">
          <i class="fas fa-envelope mr-1 text-dark-400"></i> Email
        </label>
        <input type="email" name="email" value="{{ last_username }}" autocomplete="email" required
          class="form-input" placeholder="votre@email.com" autofocus>
      </div>

      <div>
        <label class="block text-sm font-medium text-dark-700 mb-1">
          <i class="fas fa-lock mr-1 text-dark-400"></i> Mot de passe
        </label>
        <div class="relative" x-data="{ show: false }">
          <input :type="show ? 'text' : 'password'" name="password" autocomplete="current-password" required
            class="form-input pr-10" placeholder="••••••••">
          <button type="button" @click="show = !show"
            class="absolute right-3 top-1/2 -translate-y-1/2 text-dark-400 hover:text-dark-600">
            <i :class="show ? 'fas fa-eye-slash' : 'fas fa-eye'" class="text-sm"></i>
          </button>
        </div>
      </div>

      <div class="flex items-center">
        <label class="flex items-center gap-2 text-sm text-dark-500 cursor-pointer">
          <input type="checkbox" name="_remember_me" class="rounded border-gray-300 text-eco-500 focus:ring-eco-400">
          Se souvenir de moi
        </label>
      </div>

      <button type="submit" class="btn-primary w-full py-2.5 text-sm">
        <i class="fas fa-arrow-right-to-bracket"></i> Se connecter
      </button>
    </form>
  </div>

  {# Demo accounts #}
  <div class="w-full sm:max-w-md mt-4 px-6 py-4 bg-white/5 border border-white/10 sm:rounded-xl"
    x-data="{ show: false }" x-init="setTimeout(() => show = true, 350)" x-show="show"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 translate-y-4"
    x-transition:enter-end="opacity-100 translate-y-0">
    <p class="text-xs font-medium text-white/40 uppercase tracking-wider mb-3">Comptes de démonstration</p>
    <div class="space-y-1.5">
      <button onclick="fillLogin('admin@ecofasthotel.com','ecofasthotel')"
        class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm text-left hover:bg-white/10 transition-colors group">
        <span class="w-7 h-7 bg-navy-700 rounded-md flex items-center justify-center text-white text-xs font-bold">A</span>
        <div class="flex-1">
          <div class="font-medium text-white/80 text-sm">Administrateur</div>
          <div class="text-white/40 text-xs">admin@ecofasthotel.com</div>
        </div>
        <i class="fas fa-chevron-right text-xs text-white/30 group-hover:text-eco-400 transition-colors"></i>
      </button>
      <button onclick="fillLogin('hotel@ecofasthotel.com','ecofasthotel')"
        class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm text-left hover:bg-white/10 transition-colors group">
        <span class="w-7 h-7 bg-eco-600 rounded-md flex items-center justify-center text-white text-xs font-bold">H</span>
        <div class="flex-1">
          <div class="font-medium text-white/80 text-sm">Hôtel</div>
          <div class="text-white/40 text-xs">hotel@ecofasthotel.com</div>
        </div>
        <i class="fas fa-chevron-right text-xs text-white/30 group-hover:text-eco-400 transition-colors"></i>
      </button>
      <button onclick="fillLogin('chauffeur@ecofasthotel.com','ecofasthotel')"
        class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm text-left hover:bg-white/10 transition-colors group">
        <span class="w-7 h-7 bg-blue-600 rounded-md flex items-center justify-center text-white text-xs font-bold">C</span>
        <div class="flex-1">
          <div class="font-medium text-white/80 text-sm">Chauffeur</div>
          <div class="text-white/40 text-xs">chauffeur@ecofasthotel.com</div>
        </div>
        <i class="fas fa-chevron-right text-xs text-white/30 group-hover:text-eco-400 transition-colors"></i>
      </button>
    </div>
  </div>

  <p class="text-center text-white/20 text-xs mt-6 mb-4">© 2026 EcoFast VTC</p>
</div>

<script>
function fillLogin(email, password) {
  document.querySelector('input[name="email"]').value = email;
  document.querySelector('input[name="password"]').value = password;
  document.querySelector('form').submit();
}
</script>
{% endblock %}
