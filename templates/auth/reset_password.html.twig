{% extends 'base.html.twig' %}

{% block title %}Réinitialiser mon mot de passe{% endblock %}

{% block body %}
<div class="min-h-screen bg-navy-950 flex items-center justify-center p-4">
  <div class="w-full max-w-md animate-fade-in-up">

    {# Logo #}
    <div class="text-center mb-8">
      <a href="{{ path('app_login') }}">
        <img src="/images/logo.png" alt="Cabsolu" class="h-20 w-auto mx-auto drop-shadow-xl" onerror="this.style.display='none'">
        <div class="text-2xl font-bold text-eco-400 mt-2" style="font-family:'Inter',sans-serif;">Cabsolu</div>
      </a>
    </div>

    <div class="card p-8">

      {% if invalid %}
        {# Lien invalide ou expiré #}
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-circle-xmark text-red-500 text-2xl"></i>
          </div>
          <h1 class="text-xl font-bold text-dark-900 mb-3">Lien invalide ou expiré</h1>
          <p class="text-dark-400 text-sm">Ce lien de réinitialisation n'est plus valide. Les liens expirent après 1 heure.</p>
          <a href="{{ path('app_forgot_password') }}" class="btn-primary mt-5 inline-flex items-center gap-2">
            <i class="fas fa-rotate-right text-sm"></i> Faire une nouvelle demande
          </a>
        </div>

      {% elseif success %}
        {# Succès #}
        <div class="text-center">
          <div class="w-16 h-16 bg-eco-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-circle-check text-eco-600 text-2xl"></i>
          </div>
          <h1 class="text-xl font-bold text-dark-900 mb-3">Mot de passe réinitialisé !</h1>
          <p class="text-dark-400 text-sm">Vous pouvez maintenant vous connecter avec votre nouveau mot de passe.</p>
          <a href="{{ path('app_login') }}" class="btn-primary mt-5 inline-flex items-center gap-2">
            <i class="fas fa-arrow-right-to-bracket text-sm"></i> Se connecter
          </a>
        </div>

      {% else %}
        {# Formulaire de nouveau mot de passe #}
        <div class="text-center mb-6">
          <div class="w-14 h-14 bg-eco-50 rounded-full flex items-center justify-center mx-auto mb-3">
            <i class="fas fa-lock text-eco-600 text-xl"></i>
          </div>
          <h1 class="text-xl font-bold text-dark-900">Nouveau mot de passe</h1>
          <p class="text-dark-400 text-sm mt-1">Choisissez un mot de passe sécurisé (8 caractères minimum).</p>
        </div>

        {% if error is defined and error %}
          <div class="bg-red-50 border border-red-200 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-red-700">
            <i class="fas fa-triangle-exclamation text-red-500"></i> {{ error }}
          </div>
        {% endif %}

        <form method="post" x-data="{ show1: false, show2: false }" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-dark-700 mb-1.5">
              <i class="fas fa-lock mr-1.5 text-dark-400"></i>Nouveau mot de passe
            </label>
            <div class="relative">
              <input
                :type="show1 ? 'text' : 'password'"
                name="password"
                required
                minlength="8"
                autofocus
                placeholder="••••••••"
                class="w-full px-4 py-3 pr-11 border border-dark-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-eco-400 focus:border-eco-400 transition-all"
              >
              <button type="button" @click="show1=!show1" class="absolute right-3 top-1/2 -translate-y-1/2 text-dark-400 hover:text-dark-600 transition-colors">
                <i :class="show1 ? 'fas fa-eye-slash' : 'fas fa-eye'" class="text-sm"></i>
              </button>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-dark-700 mb-1.5">
              <i class="fas fa-lock mr-1.5 text-dark-400"></i>Confirmer le mot de passe
            </label>
            <div class="relative">
              <input
                :type="show2 ? 'text' : 'password'"
                name="confirm"
                required
                placeholder="••••••••"
                class="w-full px-4 py-3 pr-11 border border-dark-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-eco-400 focus:border-eco-400 transition-all"
              >
              <button type="button" @click="show2=!show2" class="absolute right-3 top-1/2 -translate-y-1/2 text-dark-400 hover:text-dark-600 transition-colors">
                <i :class="show2 ? 'fas fa-eye-slash' : 'fas fa-eye'" class="text-sm"></i>
              </button>
            </div>
          </div>

          <button type="submit" class="w-full btn-primary py-3 flex items-center justify-center gap-2">
            <i class="fas fa-circle-check"></i>
            Valider le nouveau mot de passe
          </button>
        </form>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
