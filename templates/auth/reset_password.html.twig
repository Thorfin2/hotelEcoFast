{% extends 'base.html.twig' %}

{% block title %}Réinitialiser mon mot de passe{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12" style="background: linear-gradient(160deg, #0c1b2e 0%, #0d1e33 50%, #162840 100%);">

  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#c4905a 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative w-full max-w-md animate-fade-in-up">

    {# Logo #}
    <div class="text-center mb-8">
      <a href="{{ path('app_login') }}">
        <img src="/images/logo.png" alt="" class="h-24 w-24 mx-auto drop-shadow-xl rounded-full ring-2 ring-gold-500/20" onerror="this.style.display='none'">
      </a>
    </div>

    {# Filet or #}
    <div class="h-0.5 rounded-t-2xl" style="background: linear-gradient(90deg, transparent, #c4905a 40%, #e6bc5c 60%, transparent);"></div>

    <div class="bg-white/98 rounded-b-2xl shadow-2xl px-8 py-8">

      {% if invalid %}
        <div class="text-center py-2">
          <div class="w-16 h-16 bg-red-50 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <i class="fas fa-circle-xmark text-red-500 text-2xl"></i>
          </div>
          <h1 class="text-xl font-bold text-dark-900 mb-3">Lien invalide ou expiré</h1>
          <p class="text-dark-400 text-sm">Ce lien de réinitialisation n'est plus valide. Les liens expirent après 1 heure.</p>
          <a href="{{ path('app_forgot_password') }}" class="btn-primary mt-6 inline-flex rounded-xl py-2.5 px-6">
            <i class="fas fa-rotate-right text-sm"></i> Faire une nouvelle demande
          </a>
        </div>

      {% elseif success %}
        <div class="text-center py-2">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-5" style="background:linear-gradient(135deg,#fdf6ee,#f9eccc);">
            <i class="fas fa-circle-check text-2xl" style="color:#c4905a;"></i>
          </div>
          <h1 class="text-xl font-bold text-dark-900 mb-3">Mot de passe réinitialisé !</h1>
          <p class="text-dark-400 text-sm">Vous pouvez maintenant vous connecter avec votre nouveau mot de passe.</p>
          <a href="{{ path('app_login') }}" class="btn-primary mt-6 inline-flex rounded-xl py-2.5 px-6">
            <i class="fas fa-arrow-right-to-bracket text-sm"></i> Se connecter
          </a>
        </div>

      {% else %}
        <div class="mb-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background:linear-gradient(135deg,#fdf6ee,#f9eccc);">
              <i class="fas fa-lock" style="color:#c4905a;"></i>
            </div>
            <div>
              <h1 class="text-lg font-bold" style="color:#0c1b2e;">Nouveau mot de passe</h1>
              <p class="text-dark-400 text-sm">8 caractères minimum.</p>
            </div>
          </div>
        </div>

        {% if error is defined and error %}
          <div class="bg-red-50 border border-red-200 rounded-xl p-3.5 mb-5 flex items-center gap-2 text-sm text-red-700">
            <i class="fas fa-triangle-exclamation text-red-500 flex-shrink-0"></i> {{ error }}
          </div>
        {% endif %}

        <form method="post" x-data="{ show1: false, show2: false }" class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-dark-700 mb-1.5">
              <i class="fas fa-lock mr-1.5 text-dark-300 text-xs"></i>Nouveau mot de passe
            </label>
            <div class="relative">
              <input
                :type="show1 ? 'text' : 'password'"
                name="password"
                required
                minlength="8"
                autofocus
                placeholder="••••••••"
                class="form-input rounded-xl py-3 pr-11"
              >
              <button type="button" @click="show1=!show1" class="absolute right-3 top-1/2 -translate-y-1/2 text-dark-300 hover:text-dark-600 transition-colors p-1">
                <i :class="show1 ? 'fas fa-eye-slash' : 'fas fa-eye'" class="text-sm"></i>
              </button>
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-dark-700 mb-1.5">
              <i class="fas fa-lock mr-1.5 text-dark-300 text-xs"></i>Confirmer le mot de passe
            </label>
            <div class="relative">
              <input
                :type="show2 ? 'text' : 'password'"
                name="confirm"
                required
                placeholder="••••••••"
                class="form-input rounded-xl py-3 pr-11"
              >
              <button type="button" @click="show2=!show2" class="absolute right-3 top-1/2 -translate-y-1/2 text-dark-300 hover:text-dark-600 transition-colors p-1">
                <i :class="show2 ? 'fas fa-eye-slash' : 'fas fa-eye'" class="text-sm"></i>
              </button>
            </div>
          </div>

          <button type="submit" class="w-full btn-primary py-3 rounded-xl font-semibold">
            <i class="fas fa-circle-check"></i>
            Valider le nouveau mot de passe
          </button>
        </form>
      {% endif %}
    </div>
  </div>

  <p class="relative text-center text-white/20 text-xs mt-8">© {{ 'now'|date('Y') }} Cabsolu</p>
</div>
{% endblock %}
