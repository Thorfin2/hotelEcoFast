{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12" style="background: linear-gradient(160deg, #0c1b2e 0%, #0d1e33 50%, #162840 100%);">

  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#c4905a 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative w-full max-w-md animate-fade-in-up">

    {# Logo #}
    <div class="text-center mb-8">
      <a href="{{ path('app_login') }}">
        <img src="/images/logo.png" alt="" class="h-24 w-24 mx-auto drop-shadow-xl rounded-full ring-2 ring-gold-500/20" onerror="this.style.display='none'">
      </a>
    </div>

    {# Filet or #}
    <div class="h-0.5 rounded-t-2xl" style="background: linear-gradient(90deg, transparent, #c4905a 40%, #e6bc5c 60%, transparent);"></div>

    <div class="bg-white/98 rounded-b-2xl shadow-2xl px-8 py-8">
      {% if sent %}
        {# Message de confirmation #}
        <div class="text-center py-2">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-5" style="background:linear-gradient(135deg,#fdf6ee,#f9eccc);">
            <i class="fas fa-paper-plane text-2xl" style="color:#c4905a;"></i>
          </div>
          <h1 class="text-xl font-bold mb-3" style="color:#0c1b2e;">Email envoyé !</h1>
          <p class="text-dark-400 text-sm leading-relaxed">
            Si un compte existe avec cette adresse, vous recevrez un lien de réinitialisation sous quelques minutes.<br>
            <span class="text-dark-300 text-xs mt-2 block">Pensez à vérifier vos spams.</span>
          </p>
          <a href="{{ path('app_login') }}" class="btn-primary mt-6 inline-flex rounded-xl py-2.5 px-6">
            <i class="fas fa-arrow-left text-sm"></i> Retour à la connexion
          </a>
        </div>

      {% else %}
        {# Formulaire #}
        <div class="mb-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background:linear-gradient(135deg,#fdf6ee,#f9eccc);">
              <i class="fas fa-key" style="color:#c4905a;"></i>
            </div>
            <div>
              <h1 class="text-lg font-bold" style="color:#0c1b2e;">Mot de passe oublié ?</h1>
              <p class="text-dark-400 text-sm">Saisissez votre email pour recevoir un lien.</p>
            </div>
          </div>
        </div>

        <form method="post" class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-dark-700 mb-1.5">
              <i class="fas fa-envelope mr-1.5 text-dark-300 text-xs"></i>Adresse email
            </label>
            <input
              type="email"
              name="email"
              required
              autofocus
              placeholder="votre@email.com"
              class="form-input rounded-xl py-3"
            >
          </div>

          <button type="submit" class="w-full btn-primary py-3 rounded-xl font-semibold">
            <i class="fas fa-paper-plane"></i>
            Envoyer le lien de réinitialisation
          </button>
        </form>

        <div class="mt-5 text-center">
          <a href="{{ path('app_login') }}" class="text-sm text-dark-400 hover:text-dark-700 transition-colors">
            <i class="fas fa-arrow-left mr-1 text-xs"></i> Retour à la connexion
          </a>
        </div>
      {% endif %}
    </div>
  </div>

  <p class="relative text-center text-white/20 text-xs mt-8">© {{ 'now'|date('Y') }} Cabsolu</p>
</div>
{% endblock %}
