{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="min-h-screen bg-navy-950 flex items-center justify-center p-4">
  <div class="w-full max-w-md animate-fade-in-up">

    {# Logo #}
    <div class="text-center mb-8">
      <a href="{{ path('app_login') }}">
        <img src="/images/logo.png" alt="Cabsolu" class="h-32 w-32 mx-auto drop-shadow-xl">
        <div class="text-2xl font-bold text-eco-400 mt-2" style="font-family:'Inter',sans-serif;">Cabsolu</div>
      </a>
    </div>

    <div class="card p-8">
      {% if sent %}
        {# Message de confirmation #}
        <div class="text-center">
          <div class="w-16 h-16 bg-eco-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-paper-plane text-eco-600 text-2xl"></i>
          </div>
          <h1 class="text-xl font-bold text-dark-900 mb-3">Email envoyé !</h1>
          <p class="text-dark-400 text-sm leading-relaxed">
            Si un compte existe avec cette adresse, vous recevrez un email avec un lien de réinitialisation.<br>
            <span class="text-dark-300">Vérifiez aussi vos spams.</span>
          </p>
          <a href="{{ path('app_login') }}" class="btn-primary mt-6 inline-flex items-center gap-2">
            <i class="fas fa-arrow-left text-sm"></i> Retour à la connexion
          </a>
        </div>

      {% else %}
        {# Formulaire #}
        <div class="text-center mb-6">
          <div class="w-14 h-14 bg-navy-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <i class="fas fa-key text-navy-600 text-xl"></i>
          </div>
          <h1 class="text-xl font-bold text-dark-900">Mot de passe oublié ?</h1>
          <p class="text-dark-400 text-sm mt-1">Entrez votre adresse email pour recevoir un lien de réinitialisation.</p>
        </div>

        <form method="post" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-dark-700 mb-1.5">
              <i class="fas fa-envelope mr-1.5 text-dark-400"></i>Adresse email
            </label>
            <input
              type="email"
              name="email"
              required
              autofocus
              placeholder="votre@email.com"
              class="w-full px-4 py-3 border border-dark-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-eco-400 focus:border-eco-400 transition-all"
            >
          </div>

          <button type="submit" class="w-full btn-primary py-3 flex items-center justify-center gap-2">
            <i class="fas fa-paper-plane"></i>
            Envoyer le lien de réinitialisation
          </button>
        </form>

        <div class="mt-5 text-center">
          <a href="{{ path('app_login') }}" class="text-sm text-dark-400 hover:text-dark-600 transition-colors">
            <i class="fas fa-arrow-left mr-1"></i> Retour à la connexion
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
