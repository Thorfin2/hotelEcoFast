{% extends 'driver/base.html.twig' %}

{% block title %}Mon profil{% endblock %}
{% block page_title %}Mon profil{% endblock %}

{% block content %}
<div class="max-w-lg">
  <div class="card p-6">
    <div class="flex items-center gap-4 mb-6">
      <div class="w-16 h-16 rounded-full flex items-center justify-center text-white text-2xl font-bold
        {% if driver.status == 'available' %}bg-green-500
        {% elseif driver.status == 'busy' %}bg-amber-500
        {% else %}bg-gray-400{% endif %}">
        {{ driver.firstName|first }}{{ driver.lastName|first }}
      </div>
      <div>
        <h2 class="text-xl font-bold font-display text-dark-900">{{ driver.fullName }}</h2>
        <p class="text-dark-400">{{ driver.vehicleModel }} · {{ driver.licensePlate }}</p>
      </div>
    </div>

    <div class="space-y-3 text-sm mb-6">
      {% if driver.phone %}<div class="flex items-center gap-2"><i class="fas fa-phone"></i><span>{{ driver.phone }}</span></div>{% endif %}
      {% if driver.email %}<div class="flex items-center gap-2"><i class="fas fa-envelope"></i><span>{{ driver.email }}</span></div>{% endif %}
      <div class="flex items-center gap-2"><i class="fas fa-car"></i><span>{{ driver.vehicleType }} · {{ driver.vehicleModel }}</span></div>
      <div class="flex items-center gap-2"><i class="fas fa-key"></i><span class="font-mono bg-dark-100 px-2 py-0.5 rounded">{{ driver.licensePlate }}</span></div>
    </div>

    <form method="post" class="space-y-4">
      <div>
        <label class="block text-sm font-semibold text-dark-700 mb-2">Changer mon statut</label>
        <div class="grid grid-cols-2 gap-2">
          <button name="status" value="available"
            class="py-3 rounded-xl text-sm font-semibold border-2 transition-all
              {% if driver.status == 'available' %}bg-green-50 border-green-500 text-green-700{% else %}bg-white border-dark-200 text-dark-400 hover:border-green-300{% endif %}">
            <i class="fas fa-circle-check text-eco-500"></i> Disponible
          </button>
          <button name="status" value="offline"
            class="py-3 rounded-xl text-sm font-semibold border-2 transition-all
              {% if driver.status == 'offline' %}bg-dark-100 border-dark-500 text-dark-600{% else %}bg-white border-dark-200 text-dark-400 hover:border-dark-400{% endif %}">
            <i class="fas fa-moon"></i> Hors ligne
          </button>
        </div>
      </div>
    </form>
  </div>
</div>
{% endblock %}
