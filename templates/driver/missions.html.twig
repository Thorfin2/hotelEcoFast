{% extends 'driver/base.html.twig' %}

{% block title %}Mes missions{% endblock %}
{% block page_title %}Mes missions{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">{{ rides|length }} mission(s)</p>{% endblock %}

{% block content %}
<div class="flex gap-2 mb-5 flex-wrap stagger-in">
  {% set statuses = {'' : 'Toutes', 'assigned': 'Assignées', 'confirmed': 'Confirmées', 'in_progress': 'En cours', 'completed': 'Terminées'} %}
  {% for value, label in statuses %}
    <a href="{{ path('driver_missions', value ? {status: value} : {}) }}"
       class="filter-pill px-4 py-2 rounded-full text-sm font-medium
         {% if currentStatus == value or (value == '' and currentStatus is null) %}
           bg-dark-900 text-gold-300 shadow-sm
         {% else %}bg-white text-dark-500 border border-dark-200 hover:bg-gold-50 hover:border-gold-300{% endif %}">
      {{ label }}
    </a>
  {% endfor %}
</div>

{% if rides is empty %}
  <div class="card p-12 text-center">
    <div class="text-5xl mb-4"><i class="fas fa-car"></i></div>
    <p class="text-dark-400">Aucune mission {{ currentStatus ? 'avec ce statut' : '' }}</p>
  </div>
{% else %}
  <div class="space-y-3 stagger-in">
    {% for ride in rides %}
      <div class="card p-5 transition-all duration-300 hover:shadow-lg hover:translate-x-1 group">
        <div class="flex items-start gap-4">
          <div class="text-3xl mt-1 transition-transform duration-300 group-hover:scale-110">{{ ride.statusIcon }}</div>
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="font-bold font-display text-dark-900">{{ ride.clientName }}</span>
              <span class="font-mono text-xs text-dark-300 bg-dark-100 px-1.5 py-0.5 rounded">{{ ride.reference }}</span>
            </div>
            <div class="space-y-1 text-sm text-dark-500 mb-2">
              <div><span class="text-green-500">●</span> {{ ride.pickupAddress }}</div>
              <div><span class="text-red-400">●</span> {{ ride.destinationAddress }}</div>
            </div>
            <div class="flex items-center gap-4 text-xs text-dark-300">
              <span><i class="fas fa-calendar-days mr-1"></i>{{ ride.pickupDatetime|date('d/m/Y H:i') }}</span>
              <span><i class="fas fa-users mr-1"></i>{{ ride.passengers }} pers.</span>
              {% if ride.price %}<span><i class="fas fa-euro-sign mr-1"></i>{{ ride.driverAmount }} €</span>{% endif %}
            </div>
          </div>
          <div class="flex flex-col items-end gap-2">
            <span class="badge
              {% if ride.status == 'assigned' %}bg-blue-100 text-blue-800
              {% elseif ride.status == 'confirmed' %}bg-indigo-100 text-indigo-800
              {% elseif ride.status == 'in_progress' %}bg-purple-100 text-purple-800
              {% elseif ride.status == 'completed' %}bg-green-100 text-green-800
              {% else %}bg-dark-100 text-gray-800{% endif %}">
              {{ ride.statusLabel }}
            </span>
            <a href="{{ path('driver_mission_detail', {id: ride.id}) }}" class="btn-secondary text-xs py-1.5">Détail →</a>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}
{% endblock %}
