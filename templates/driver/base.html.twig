{% extends 'layout/app.html.twig' %}

{% block nav_links %}
  <a href="{{ path('driver_dashboard') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') == 'driver_dashboard' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Tableau de bord
  </a>
  <a href="{{ path('driver_missions') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') starts with 'driver_mission' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Mes missions
  </a>
  <a href="{{ path('driver_profile') }}"
    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') == 'driver_profile' ? 'text-gold-700 bg-gold-50' : 'text-dark-500 hover:text-dark-900 hover:bg-gray-50' }}">
    Mon profil
  </a>
{% endblock %}

{% block mobile_nav %}
  <a href="{{ path('driver_dashboard') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') == 'driver_dashboard' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Tableau de bord</a>
  <a href="{{ path('driver_missions') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') starts with 'driver_mission' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Mes missions</a>
  <a href="{{ path('driver_profile') }}" class="block px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') == 'driver_profile' ? 'text-gold-700 bg-gold-50' : 'text-dark-600 hover:bg-gray-50' }}">Mon profil</a>
{% endblock %}
