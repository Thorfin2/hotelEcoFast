{% extends 'layout/app.html.twig' %}

{% block nav_links %}
  <a href="{{ path('driver_dashboard') }}"
    class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') == 'driver_dashboard' ? 'text-gold-400 bg-navy-800' : 'text-white/70 hover:text-white hover:bg-navy-800' }}">
    <i class="fas fa-gauge-high text-xs"></i> Tableau de bord
  </a>
  <a href="{{ path('driver_missions') }}"
    class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') starts with 'driver_mission' ? 'text-gold-400 bg-navy-800' : 'text-white/70 hover:text-white hover:bg-navy-800' }}">
    <i class="fas fa-route text-xs"></i> Mes missions
  </a>
  <a href="{{ path('driver_profile') }}"
    class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-md transition-colors
      {{ app.request.attributes.get('_route') == 'driver_profile' ? 'text-gold-400 bg-navy-800' : 'text-white/70 hover:text-white hover:bg-navy-800' }}">
    <i class="fas fa-user text-xs"></i> Mon profil
  </a>
{% endblock %}

{% block mobile_nav %}
  <a href="{{ path('driver_dashboard') }}" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') == 'driver_dashboard' ? 'text-gold-400 bg-navy-800' : 'text-white/70 hover:bg-navy-800 hover:text-white' }}"><i class="fas fa-gauge-high w-4"></i> Tableau de bord</a>
  <a href="{{ path('driver_missions') }}" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') starts with 'driver_mission' ? 'text-gold-400 bg-navy-800' : 'text-white/70 hover:bg-navy-800 hover:text-white' }}"><i class="fas fa-route w-4"></i> Mes missions</a>
  <a href="{{ path('driver_profile') }}" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium {{ app.request.attributes.get('_route') == 'driver_profile' ? 'text-gold-400 bg-navy-800' : 'text-white/70 hover:bg-navy-800 hover:text-white' }}"><i class="fas fa-user w-4"></i> Mon profil</a>
{% endblock %}
