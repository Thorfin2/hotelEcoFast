{% extends 'hotel/base.html.twig' %}

{% block title %}Commissions{% endblock %}
{% block page_title %}Commissions{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">{{ hotel.name }} · {{ month|date('F Y') }}</p>{% endblock %}

{% block header_actions %}
  {% if rides is not empty %}
    <a href="{{ path('hotel_commissions', {month: month|date('Y-m'), send_report: 1}) }}"
       class="btn-primary text-sm">
      <i class="fas fa-envelope mr-1"></i>Envoyer le relevé par email
    </a>
  {% endif %}
{% endblock %}

{% block content %}
{# Month picker #}
<div class="flex items-center gap-3 mb-6">
  <a href="{{ path('hotel_commissions', {month: month|date_modify('-1 month')|date('Y-m')}) }}" class="btn-secondary py-2">← Mois précédent</a>
  <form method="get" class="flex items-center gap-2">
    <input type="month" name="month" value="{{ month|date('Y-m') }}" class="form-input w-auto">
    <button type="submit" class="btn-secondary py-2">Filtrer</button>
  </form>
  <a href="{{ path('hotel_commissions', {month: month|date_modify('+1 month')|date('Y-m')}) }}" class="btn-secondary py-2">Mois suivant →</a>
</div>

{# Summary card #}
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="card p-5" style="background: linear-gradient(135deg, #fdf9ef, #fff); border-color: #f4dea8;">
    <div class="text-xs font-semibold text-gold-600 uppercase tracking-wider mb-2">Total commissions</div>
    <div class="text-3xl font-bold text-gold-700">{{ total|number_format(2, ',', ' ') }} €</div>
    <div class="text-xs text-gold-500 mt-1">{{ month|date('F Y') }}</div>
  </div>
  <div class="card p-5">
    <div class="text-xs font-semibold text-dark-400 uppercase tracking-wider mb-2">Courses terminées</div>
    <div class="text-3xl font-bold text-dark-900">{{ rides|length }}</div>
    <div class="text-xs text-dark-300 mt-1">Ce mois</div>
  </div>
  <div class="card p-5">
    <div class="text-xs font-semibold text-dark-400 uppercase tracking-wider mb-2">Taux de commission</div>
    <div class="text-3xl font-bold text-dark-900">{{ hotel.commissionRate }}%</div>
    <div class="text-xs text-dark-300 mt-1">Taux contractuel</div>
  </div>
</div>

{% if rides is empty %}
  <div class="card p-12 text-center">
    <div class="text-5xl mb-4"><i class="fas fa-chart-bar"></i></div>
    <p class="text-dark-400">Aucune course terminée ce mois-ci</p>
  </div>
{% else %}
  <div class="card overflow-hidden">
    <div class="flex items-center justify-between p-5 border-b border-dark-100">
      <h2 class="font-semibold text-dark-900 font-display">Détail des courses — {{ month|date('F Y') }}</h2>
      <span class="text-sm text-dark-300">{{ rides|length }} course(s)</span>
    </div>
    <table class="w-full">
      <thead>
        <tr class="bg-dark-50 border-b border-dark-100">
          <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider">Référence</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider">Client</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider">Date</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider">Chauffeur</th>
          <th class="text-right px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider">Prix</th>
          <th class="text-right px-5 py-3 text-xs font-semibold text-gold-600 uppercase tracking-wider">Commission</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        {% for ride in rides %}
          <tr class="hover:bg-gold-50/50">
            <td class="px-5 py-3.5">
              <a href="{{ path('hotel_ride_detail', {id: ride.id}) }}" class="font-mono text-xs bg-dark-50 text-gold-600 hover:text-gold-800 px-2 py-1 rounded font-semibold">{{ ride.reference }}</a>
            </td>
            <td class="px-5 py-3.5 text-sm text-dark-900 font-medium">{{ ride.clientName }}</td>
            <td class="px-5 py-3.5 text-sm text-dark-500">{{ ride.pickupDatetime|date('d/m/Y') }}</td>
            <td class="px-5 py-3.5 text-sm text-dark-500">{{ ride.driver ? ride.driver.fullName : '—' }}</td>
            <td class="px-5 py-3.5 text-sm text-dark-900 font-medium text-right">{{ ride.price }} €</td>
            <td class="px-5 py-3.5 text-right">
              <span class="font-bold text-gold-700 text-base">{{ ride.hotelCommission }} €</span>
            </td>
          </tr>
        {% endfor %}
      </tbody>
      <tfoot>
        <tr class="bg-gold-50 border-t-2 border-gold-300">
          <td colspan="5" class="px-5 py-4 font-bold text-gold-800">Total {{ month|date('F Y') }}</td>
          <td class="px-5 py-4 text-right font-bold text-gold-800 text-xl">{{ total|number_format(2, ',', ' ') }} €</td>
        </tr>
      </tfoot>
    </table>
  </div>
{% endif %}
{% endblock %}
