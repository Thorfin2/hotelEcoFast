{% extends 'hotel/base.html.twig' %}

{% block title %}Nouvelle course{% endblock %}
{% block page_title %}Nouvelle course{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">Renseignez les informations du transport</p>{% endblock %}

{% block header_actions %}
  <a href="{{ path('hotel_dashboard') }}" class="btn-secondary">&larr; Retour</a>
{% endblock %}

{% block content %}
{{ form_start(form, {attr: {class: 'max-w-3xl', id: 'ride-form'}}) }}

<div class="space-y-6">

  {# Client info #}
  <div class="card p-6">
    <h2 class="font-semibold text-dark-900 mb-4 flex items-center gap-2">
      <span class="w-7 h-7 bg-gold-100 text-gold-600 rounded-lg flex items-center justify-center text-sm">&#128100;</span>
      Informations client
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="md:col-span-3">
        <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.clientName) }}</label>
        {{ form_widget(form.clientName) }}
        {{ form_errors(form.clientName) }}
      </div>
      <div>
        <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.clientPhone) }}</label>
        {{ form_widget(form.clientPhone) }}
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.clientEmail) }}</label>
        {{ form_widget(form.clientEmail) }}
      </div>
    </div>
  </div>

  {# Ride details #}
  <div class="card p-6">
    <h2 class="font-semibold text-dark-900 mb-4 flex items-center gap-2">
      <span class="w-7 h-7 bg-dark-100 text-dark-600 rounded-lg flex items-center justify-center text-sm">&#128663;</span>
      D&eacute;tails du trajet
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.pickupAddress) }}</label>
        {{ form_widget(form.pickupAddress) }}
        {{ form_errors(form.pickupAddress) }}
      </div>
      <div>
        <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.destinationAddress) }}</label>
        {{ form_widget(form.destinationAddress) }}
        {{ form_errors(form.destinationAddress) }}
      </div>
      <div>
        <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.pickupDatetime) }}</label>
        {{ form_widget(form.pickupDatetime) }}
        {{ form_errors(form.pickupDatetime) }}
      </div>
      <div>
        <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.rideType) }}</label>
        {{ form_widget(form.rideType) }}
      </div>
      <div>
        <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.passengers) }}</label>
        {{ form_widget(form.passengers) }}
      </div>
      <div>
        <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.luggage) }}</label>
        {{ form_widget(form.luggage) }}
      </div>
      <div>
        <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.flightNumber) }}</label>
        {{ form_widget(form.flightNumber) }}
      </div>
    </div>
  </div>

  {# Distance & Price calculation #}
  <div class="card p-6" x-data="priceCalculator()" x-ref="priceCard">
    <h2 class="font-semibold text-dark-900 mb-4 flex items-center gap-2">
      <span class="w-7 h-7 bg-green-100 text-green-600 rounded-lg flex items-center justify-center text-sm">&#128200;</span>
      Estimation du prix
    </h2>

    {# Loading state #}
    <div x-show="loading" class="flex items-center gap-3 py-4">
      <div class="animate-spin w-5 h-5 border-2 border-gold-600 border-t-transparent rounded-full"></div>
      <span class="text-dark-500 text-sm">Calcul de la distance en cours...</span>
    </div>

    {# Error state #}
    <div x-show="error && !loading" x-cloak class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
      <p class="text-red-700 text-sm" x-text="error"></p>
    </div>

    {# Result #}
    <div x-show="distance > 0 && !loading" x-cloak
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <div class="text-dark-400 text-xs uppercase tracking-wider mb-1">Distance</div>
          <div class="text-2xl font-bold text-dark-900" x-text="distance.toFixed(1) + ' km'"></div>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <div class="text-dark-400 text-xs uppercase tracking-wider mb-1">Dur&eacute;e estim&eacute;e</div>
          <div class="text-2xl font-bold text-dark-900" x-text="duration"></div>
        </div>
        <div class="bg-gold-50 border border-gold-200 rounded-lg p-4 text-center">
          <div class="text-gold-600 text-xs uppercase tracking-wider mb-1">Prix estim&eacute;</div>
          <div class="text-2xl font-bold text-gold-700" x-text="price.toFixed(2) + ' \u20ac'"></div>
        </div>
      </div>

      <div class="text-xs text-dark-400 space-y-1">
        <p>Calcul : <span x-text="distance.toFixed(1)"></span> km &times; {{ pricePerKm }} &euro;/km = <span x-text="(distance * {{ pricePerKm }}).toFixed(2)"></span> &euro;
          <span x-show="(distance * {{ pricePerKm }}) < {{ minimumPrice }}" class="text-amber-600">(minimum {{ minimumPrice }} &euro; appliqu&eacute;)</span>
        </p>
        <p>Commission h&ocirc;tel ({{ hotel.commissionRate }}%) : <span x-text="(price * {{ hotel.commissionRate }} / 100).toFixed(2)"></span> &euro;</p>
      </div>
    </div>

    {# Manual price fallback #}
    <div x-show="manualMode" x-cloak class="mt-4 p-4 bg-amber-50 border border-amber-200 rounded-lg">
      <p class="text-amber-800 text-sm font-medium mb-3">Saisie manuelle du prix</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-dark-700 mb-1.5">Distance (km)</label>
          <input type="number" step="0.1" min="0" placeholder="Ex: 35"
            class="form-input"
            @input="distance = parseFloat($event.target.value) || 0; calculatePrice()">
        </div>
        <div>
          <label class="block text-sm font-semibold text-dark-700 mb-1.5">ou Prix direct (&euro;)</label>
          <input type="number" step="0.01" min="0" placeholder="Ex: 85.00"
            class="form-input"
            @input="setManualPrice($event.target.value)">
        </div>
      </div>
    </div>

    {# Waiting state #}
    <div x-show="distance === 0 && !loading && !error && !manualMode" class="text-center py-6">
      <div class="text-dark-300 text-3xl mb-2">&#128205;</div>
      <p class="text-dark-400 text-sm">Saisissez les adresses de d&eacute;part et destination pour calculer automatiquement le prix</p>
      <button type="button" @click="enableManualMode()" class="mt-3 text-xs text-gold-600 hover:text-gold-800 underline">Saisir le prix manuellement</button>
    </div>

    {{ form_widget(form.distanceKm) }}
    {{ form_widget(form.price) }}
  </div>

  {# Notes #}
  <div class="card p-6">
    <h2 class="font-semibold text-dark-900 mb-4 flex items-center gap-2">
      <span class="w-7 h-7 bg-amber-100 text-amber-600 rounded-lg flex items-center justify-center text-sm">&#128221;</span>
      Notes & Instructions
    </h2>
    <label class="block text-sm font-semibold text-dark-700 mb-1.5">{{ form_label(form.notes) }}</label>
    {{ form_widget(form.notes) }}
  </div>

  {# Notifications info #}
  <div class="bg-gold-50 border border-gold-200 rounded-xl p-4 flex items-start gap-3">
    <span class="text-gold-600 text-lg mt-0.5">&#128236;</span>
    <div>
      <p class="text-gold-800 font-semibold text-sm">Notifications automatiques</p>
      <p class="text-gold-700 text-xs mt-1">&Agrave; la cr&eacute;ation : email &agrave; l'admin + SMS simulation h&ocirc;tel
      {% if form.vars.data.clientEmail is not empty %}+ email de confirmation client{% endif %}</p>
    </div>
  </div>

  {# Submit #}
  <div class="flex items-center gap-3">
    <button type="submit" class="btn-primary text-base py-3 px-8">
      &#128663; Cr&eacute;er la course et envoyer les notifications
    </button>
    <a href="{{ path('hotel_dashboard') }}" class="btn-secondary">Annuler</a>
  </div>
</div>

{{ form_end(form) }}

<script>
function priceCalculator() {
  return {
    distance: 0,
    duration: '',
    price: 0,
    loading: false,
    error: '',
    manualMode: false,
    pricePerKm: {{ pricePerKm }},
    minimumPrice: {{ minimumPrice }},

    calculatePrice() {
      if (this.distance > 0) {
        var calculated = this.distance * this.pricePerKm;
        this.price = Math.max(calculated, this.minimumPrice);
        this.updateFields();
      }
    },

    updateFields() {
      var distanceField = document.getElementById('ride_distanceKm');
      var priceField = document.getElementById('ride_price');
      if (distanceField) distanceField.value = this.distance.toFixed(2);
      if (priceField) priceField.value = this.price.toFixed(2);
    },

    setManualPrice(val) {
      this.price = parseFloat(val) || 0;
      this.updateFields();
    },

    enableManualMode() {
      this.manualMode = true;
      this.error = '';
    }
  };
}
</script>

<script>
(g=>{var h,a,k,p="The Google Maps JavaScript API",c="google",l="importLibrary",q="__ib__",m=document,b=window;b=b[c]||(b[c]={});var d=b.maps||(b.maps={}),r=new Set,e=new URLSearchParams,u=()=>h||(h=new Promise(async(f,n)=>{await (a=m.createElement("script"));e.set("libraries",[...r]+"");for(k in g)e.set(k.replace(/[A-Z]/g,t=>"_"+t[0].toLowerCase()),g[k]);e.set("callback",c+".maps."+q);a.src=`https://maps.googleapis.com/maps/api/js?`+e;d[q]=f;a.onerror=()=>h=n(Error(p+" could not load."));a.nonce=m.querySelector("script[nonce]")?.nonce||"";m.head.append(a)}));d[l]?console.warn(p+" only loads once. Ignoring:",g):d[l]=(f,...n)=>r.add(f)&&u().then(()=>d[l](f,...n))})({
  key: "{{ googleMapsApiKey }}",
  v: "weekly"
});

var pickupPlace = null;
var destinationPlace = null;

async function initGoogleMaps() {
  try {
    var { PlaceAutocompleteElement } = await google.maps.importLibrary('places');
    await google.maps.importLibrary('routes');
  } catch (e) {
    console.error('Erreur chargement Google Maps:', e);
    enableFallback('Impossible de charger Google Maps. Utilisez la saisie manuelle.');
    return;
  }

  var pickupInput = document.getElementById('ride_pickupAddress');
  var destinationInput = document.getElementById('ride_destinationAddress');
  if (!pickupInput || !destinationInput) return;

  // Create pickup autocomplete
  var pickupAC = new PlaceAutocompleteElement({
    componentRestrictions: { country: 'fr' },
  });
  pickupAC.setAttribute('style', 'width:100%;');
  pickupAC.setAttribute('placeholder', 'Adresse de d\u00e9part...');
  pickupInput.style.display = 'none';
  pickupInput.parentNode.insertBefore(pickupAC, pickupInput.nextSibling);

  // Create destination autocomplete
  var destAC = new PlaceAutocompleteElement({
    componentRestrictions: { country: 'fr' },
  });
  destAC.setAttribute('style', 'width:100%;');
  destAC.setAttribute('placeholder', 'Adresse de destination...');
  destinationInput.style.display = 'none';
  destinationInput.parentNode.insertBefore(destAC, destinationInput.nextSibling);

  // Style the autocomplete elements
  var style = document.createElement('style');
  style.textContent = 'gmp-place-autocomplete { --gmpac-color-surface: #fff; --gmpac-color-on-surface: #1a1a2e; --gmpac-color-on-surface-variant: #6b7280; --gmpac-color-outline: #d1d5db; --gmpac-color-primary: #c8a951; border-radius: 0.5rem; font-size: 0.875rem; }';
  document.head.appendChild(style);

  // Pickup place selection
  pickupAC.addEventListener('gmp-placeselect', async function(event) {
    var place = event.place;
    try {
      await place.fetchFields({ fields: ['displayName', 'formattedAddress', 'location'] });
      pickupInput.value = place.formattedAddress || place.displayName;
      pickupPlace = place;
      tryCalculateDistance();
    } catch (e) {
      console.error('Erreur pickup:', e);
    }
  });

  // Destination place selection
  destAC.addEventListener('gmp-placeselect', async function(event) {
    var place = event.place;
    try {
      await place.fetchFields({ fields: ['displayName', 'formattedAddress', 'location'] });
      destinationInput.value = place.formattedAddress || place.displayName;
      destinationPlace = place;
      tryCalculateDistance();
    } catch (e) {
      console.error('Erreur destination:', e);
    }
  });
}

function enableFallback(msg) {
  var calcEl = document.querySelector('[x-data="priceCalculator()"]');
  if (calcEl) {
    var calculator = Alpine.$data(calcEl);
    calculator.error = msg;
    calculator.manualMode = true;
  }
}

async function tryCalculateDistance() {
  if (!pickupPlace || !destinationPlace) return;
  if (!pickupPlace.location || !destinationPlace.location) return;

  var calcEl = document.querySelector('[x-data="priceCalculator()"]');
  var calculator = Alpine.$data(calcEl);
  calculator.loading = true;
  calculator.error = '';

  try {
    var service = new google.maps.DistanceMatrixService();
    service.getDistanceMatrix({
      origins: [pickupPlace.location],
      destinations: [destinationPlace.location],
      travelMode: google.maps.TravelMode.DRIVING,
      unitSystem: google.maps.UnitSystem.METRIC,
    }, function(response, status) {
      calculator.loading = false;

      if (status !== 'OK') {
        calculator.error = 'Erreur API Distance Matrix (' + status + '). V\u00e9rifiez que l\'API est activ\u00e9e.';
        calculator.manualMode = true;
        return;
      }

      var result = response.rows[0].elements[0];
      if (result.status !== 'OK') {
        calculator.error = 'Impossible de calculer la distance entre ces adresses (' + result.status + ').';
        calculator.manualMode = true;
        return;
      }

      calculator.distance = result.distance.value / 1000;
      calculator.duration = result.duration.text;
      calculator.manualMode = false;
      calculator.calculatePrice();
    });
  } catch (e) {
    calculator.loading = false;
    calculator.error = 'Erreur: ' + e.message;
    calculator.manualMode = true;
  }
}

// Init once DOM is ready
document.addEventListener('DOMContentLoaded', initGoogleMaps);
</script>
{% endblock %}
