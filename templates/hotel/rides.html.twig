{% extends 'hotel/base.html.twig' %}

{% block title %}Mes courses{% endblock %}
{% block page_title %}Mes courses{% endblock %}
{% block page_subtitle %}<p class="text-dark-400 text-sm mt-0.5">{{ rides|length }} course(s) {{ currentStatus ? '· filtre: ' ~ currentStatus : '' }}</p>{% endblock %}

{% block header_actions %}
  <a href="{{ path('hotel_new_ride') }}" class="btn-primary">+ Nouvelle course</a>
{% endblock %}

{% block content %}
{# Filters #}
<div class="flex gap-2 mb-5 flex-wrap stagger-in">
  {% set statuses = {'' : 'Toutes', 'pending': 'En attente', 'assigned': 'Assignée', 'in_progress': 'En cours', 'completed': 'Terminée', 'cancelled': 'Annulée'} %}
  {% for value, label in statuses %}
    <a href="{{ path('hotel_rides', value ? {status: value} : {}) }}"
       class="filter-pill px-4 py-2 rounded-full text-sm font-medium
         {% if currentStatus == value or (value == '' and currentStatus is null) %}
           bg-dark-900 text-gold-300 shadow-sm
         {% else %}
           bg-white text-dark-500 border border-dark-200 hover:bg-gold-50 hover:border-gold-300
         {% endif %}">
      {{ label }}
    </a>
  {% endfor %}
</div>

{% if rides is empty %}
  <div class="card p-12 text-center animate-fade-in-up">
    <div class="text-5xl mb-4 animate-float">🚗</div>
    <p class="text-dark-400">Aucune course {{ currentStatus ? 'avec ce statut' : '' }}</p>
    <a href="{{ path('hotel_new_ride') }}" class="btn-primary mt-4 inline-flex">Créer une course</a>
  </div>
{% else %}
  <div class="card overflow-hidden">
    <table class="w-full">
      <thead>
        <tr class="bg-dark-50 border-b border-dark-100">
          <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider">Référence</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider">Client</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider hidden md:table-cell">Trajet</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider">Date</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider">Chauffeur</th>
          <th class="text-left px-5 py-3 text-xs font-semibold text-dark-400 uppercase tracking-wider">Statut</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        {% for ride in rides %}
          <tr class="hover:bg-gold-50/50 transition-all duration-200 hover:shadow-sm">
            <td class="px-5 py-4">
              <span class="font-mono text-xs bg-dark-50 text-dark-700 px-2 py-1 rounded font-semibold">{{ ride.reference }}</span>
            </td>
            <td class="px-5 py-4">
              <div class="font-semibold text-dark-900 text-sm">{{ ride.clientName }}</div>
              {% if ride.clientPhone %}<div class="text-xs text-dark-300">{{ ride.clientPhone }}</div>{% endif %}
            </td>
            <td class="px-5 py-4 hidden md:table-cell">
              <div class="text-xs text-dark-600 max-w-48 truncate">
                <span class="text-green-600">●</span> {{ ride.pickupAddress|split(',')|first }}
              </div>
              <div class="text-xs text-dark-400 max-w-48 truncate">
                <span class="text-red-400">●</span> {{ ride.destinationAddress|split(',')|first }}
              </div>
            </td>
            <td class="px-5 py-4">
              <div class="text-sm font-medium text-dark-900">{{ ride.pickupDatetime|date('d/m/Y') }}</div>
              <div class="text-xs text-dark-300">{{ ride.pickupDatetime|date('H:i') }}</div>
            </td>
            <td class="px-5 py-4">
              {% if ride.driver %}
                <div class="text-sm text-dark-900">{{ ride.driver.fullName }}</div>
              {% else %}
                <span class="text-amber-500 text-xs">Non assigné</span>
              {% endif %}
            </td>
            <td class="px-5 py-4">
              <span class="badge
                {% if ride.status == 'pending' %}bg-amber-100 text-amber-800
                {% elseif ride.status == 'completed' %}bg-green-100 text-green-800
                {% elseif ride.status == 'in_progress' %}bg-purple-100 text-purple-800
                {% elseif ride.status == 'cancelled' %}bg-red-100 text-red-800
                {% elseif ride.status == 'assigned' %}bg-blue-100 text-blue-800
                {% else %}bg-gray-100 text-gray-800{% endif %}">
                {{ ride.statusLabel }}
              </span>
            </td>
            <td class="px-5 py-4">
              <a href="{{ path('hotel_ride_detail', {id: ride.id}) }}"
                 class="text-gold-600 hover:text-gold-800 text-sm font-medium">Voir →</a>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endif %}
{% endblock %}
