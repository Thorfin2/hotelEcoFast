{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen" style="background:#f4f5f7">

  {# ── Top Navigation ──────────────────────────────────────────────────────── #}
  <nav class="bg-navy-950 shadow-lg" x-data="{ mobileOpen: false, userOpen: false }">

    {# Filet or signature Cabsolu #}
    <div class="h-0.5 w-full" style="background: linear-gradient(90deg, transparent, #c4905a 30%, #e6bc5c 50%, #c4905a 70%, transparent);"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">

        {# Left: Logo + nom + Desktop nav #}
        <div class="flex">
          {# Logo + marque #}
          <div class="flex-shrink-0 flex items-center gap-3 pr-6 border-r border-navy-800">
            <a href="{{ path('app_home') ?? '#' }}" class="flex items-center gap-2.5 group">
              <img src="/images/logo.png" alt="" class="h-9 w-9 rounded-full ring-1 ring-gold-500/30 transition-all duration-300 group-hover:ring-gold-400/60" onerror="this.style.display='none'">
              <span class="text-white font-bold text-base tracking-wide hidden md:block" style="font-family:'Inter',sans-serif;letter-spacing:0.04em;">
                CAB<span style="color:#c4905a">SOLU</span>
              </span>
            </a>
          </div>

          {# Desktop navigation links #}
          <div class="hidden sm:ml-5 sm:flex sm:items-center sm:space-x-0.5">
            {% block nav_links %}{% endblock %}
          </div>
        </div>

        {# Right: User dropdown #}
        <div class="hidden sm:ml-6 sm:flex sm:items-center">
          <div class="relative" @click.away="userOpen = false">
            <button @click="userOpen = !userOpen"
              class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium text-white/80 hover:text-white hover:bg-navy-800/70 transition-all duration-150 border border-transparent hover:border-navy-700">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold ring-2 ring-gold-500/40"
                   style="background: linear-gradient(135deg, #c4905a, #8a5630);">
                {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
              </div>
              <span class="text-white/90 font-medium">{{ app.user.firstName }}</span>
              <i class="fas fa-chevron-down text-gold-500/70 text-xs transition-transform duration-150" :class="userOpen ? 'rotate-180' : ''"></i>
            </button>

            <div x-show="userOpen" x-cloak
              x-transition:enter="transition ease-out duration-150"
              x-transition:enter-start="opacity-0 scale-95 -translate-y-1"
              x-transition:enter-end="opacity-100 scale-100 translate-y-0"
              x-transition:leave="transition ease-in duration-100"
              x-transition:leave-start="opacity-100 scale-100"
              x-transition:leave-end="opacity-0 scale-95"
              class="absolute right-0 mt-2 w-56 rounded-xl shadow-xl bg-white ring-1 ring-black/8 z-50 overflow-hidden">

              {# Header dropdown #}
              <div class="px-4 py-3 border-b border-gray-100" style="background:linear-gradient(135deg,#fdf6ee,#fff);">
                <div class="flex items-center gap-2 mb-1">
                  <i class="fas
                    {% if 'ROLE_ADMIN' in app.user.roles %}fa-shield-halved
                    {% elseif 'ROLE_HOTEL' in app.user.roles %}fa-hotel
                    {% else %}fa-steering-wheel{% endif %}
                    text-xs" style="color:#c4905a"></i>
                  <span class="text-xs font-semibold uppercase tracking-widest" style="color:#8a5630">
                    {% if 'ROLE_ADMIN' in app.user.roles %}Administrateur
                    {% elseif 'ROLE_HOTEL' in app.user.roles %}Hôtel
                    {% else %}Chauffeur{% endif %}
                  </span>
                </div>
                <div class="text-sm font-bold text-dark-900 truncate">{{ app.user.fullName }}</div>
                <div class="text-xs text-dark-400 truncate">{{ app.user.email }}</div>
              </div>

              <div class="py-1">
                {% if 'ROLE_ADMIN' in app.user.roles %}
                <a href="{{ path('admin_profile') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-dark-600 hover:bg-gold-50 hover:text-dark-900 transition-colors">
                  <i class="fas fa-user-pen w-4 text-dark-300"></i> Mon profil
                </a>
                {% endif %}
                <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-dark-600 hover:bg-red-50 hover:text-red-700 transition-colors">
                  <i class="fas fa-arrow-right-from-bracket w-4 text-dark-300"></i> Déconnexion
                </a>
              </div>
            </div>
          </div>
        </div>

        {# Mobile hamburger #}
        <div class="flex items-center sm:hidden">
          <button @click="mobileOpen = !mobileOpen" class="p-2 rounded-lg text-white/70 hover:text-white hover:bg-navy-800 transition-colors">
            <i x-show="!mobileOpen" class="fas fa-bars text-lg"></i>
            <i x-show="mobileOpen" x-cloak class="fas fa-xmark text-lg"></i>
          </button>
        </div>
      </div>
    </div>

    {# Mobile menu #}
    <div x-show="mobileOpen" x-cloak
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      class="sm:hidden border-t border-navy-800 bg-navy-950">
      <div class="pt-2 pb-3 px-4 space-y-0.5">
        {% block mobile_nav %}{% endblock %}
      </div>
      <div class="pt-3 pb-4 px-4 border-t border-navy-800/60">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-white text-xs font-bold ring-2 ring-gold-500/30"
               style="background:linear-gradient(135deg,#c4905a,#8a5630);">
            {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
          </div>
          <div>
            <div class="text-sm font-semibold text-white">{{ app.user.fullName }}</div>
            <div class="text-xs text-white/40">{{ app.user.email }}</div>
          </div>
        </div>
        <a href="{{ path('app_logout') }}" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-white/60 hover:bg-navy-800 hover:text-white transition-colors">
          <i class="fas fa-arrow-right-from-bracket"></i> Déconnexion
        </a>
      </div>
    </div>
  </nav>

  {# ── Page header ─────────────────────────────────────────────────────────── #}
  <header class="bg-white border-b border-gray-200/80 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex items-center justify-between">
      <div>
        <h2 class="text-xl font-bold leading-tight" style="color:#0c1b2e;">{% block page_title %}{% endblock %}</h2>
        {% block page_subtitle %}{% endblock %}
      </div>
      <div class="flex items-center gap-3">
        {% block header_actions %}{% endblock %}
      </div>
    </div>
  </header>

  {# ── Main content ────────────────────────────────────────────────────────── #}
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {% block content %}{% endblock %}
  </main>

</div>
{% endblock %}
