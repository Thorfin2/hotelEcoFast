{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen bg-gray-100">

  {# ── Top Navigation ──────────────────────────────────────────────────────── #}
  <nav class="bg-navy-900 shadow-md" x-data="{ mobileOpen: false, userOpen: false }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">

        {# Left: Logo + Desktop nav #}
        <div class="flex">
          {# Logo #}
          <div class="flex-shrink-0 flex items-center pr-6 border-r border-navy-700">
            <a href="{{ path('app_home') ?? '#' }}" class="flex items-center">
              <img src="/images/logo.png" alt="EcoFast VTC" class="h-9 w-auto">
            </a>
          </div>

          {# Desktop navigation links #}
          <div class="hidden sm:ml-4 sm:flex sm:items-center sm:space-x-1">
            {% block nav_links %}{% endblock %}
          </div>
        </div>

        {# Right: User dropdown #}
        <div class="hidden sm:ml-6 sm:flex sm:items-center">
          <div class="relative" @click.away="userOpen = false">
            <button @click="userOpen = !userOpen"
              class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium text-white/80 hover:text-white hover:bg-navy-800 transition-colors">
              <div class="w-8 h-8 bg-eco-500 rounded-full flex items-center justify-center text-white text-xs font-bold">
                {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
              </div>
              <span class="text-white/90">{{ app.user.firstName }}</span>
              <i class="fas fa-chevron-down text-white/50 text-xs transition-transform duration-150" :class="userOpen ? 'rotate-180' : ''"></i>
            </button>
            <div x-show="userOpen" x-cloak
              x-transition:enter="transition ease-out duration-100"
              x-transition:enter-start="opacity-0 scale-95"
              x-transition:enter-end="opacity-100 scale-100"
              x-transition:leave="transition ease-in duration-75"
              x-transition:leave-start="opacity-100 scale-100"
              x-transition:leave-end="opacity-0 scale-95"
              class="absolute right-0 mt-2 w-52 rounded-md shadow-lg bg-white ring-1 ring-black/5 z-50">
              <div class="py-1">
                <div class="px-4 py-3 border-b border-gray-100">
                  <div class="text-xs text-dark-400 font-medium uppercase tracking-wide">
                    {% if 'ROLE_ADMIN' in app.user.roles %}<i class="fas fa-shield-halved mr-1 text-navy-700"></i>Administrateur
                    {% elseif 'ROLE_HOTEL' in app.user.roles %}<i class="fas fa-hotel mr-1 text-eco-600"></i>Hôtel
                    {% elseif 'ROLE_DRIVER' in app.user.roles %}<i class="fas fa-car mr-1 text-blue-600"></i>Chauffeur
                    {% endif %}
                  </div>
                  <div class="text-sm font-semibold text-dark-900 truncate mt-0.5">{{ app.user.fullName }}</div>
                  <div class="text-xs text-dark-400 truncate">{{ app.user.email }}</div>
                </div>
                {% if 'ROLE_ADMIN' in app.user.roles %}
                <a href="{{ path('admin_profile') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-dark-600 hover:bg-gray-50 hover:text-dark-900">
                  <i class="fas fa-user-pen w-4 text-dark-400"></i> Mon profil
                </a>
                {% endif %}
                <a href="{{ path('app_logout') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-dark-600 hover:bg-gray-50 hover:text-dark-900">
                  <i class="fas fa-arrow-right-from-bracket w-4 text-dark-400"></i> Déconnexion
                </a>
              </div>
            </div>
          </div>
        </div>

        {# Mobile hamburger #}
        <div class="flex items-center sm:hidden">
          <button @click="mobileOpen = !mobileOpen" class="p-2 rounded-md text-white/70 hover:text-white hover:bg-navy-800">
            <i x-show="!mobileOpen" class="fas fa-bars text-lg"></i>
            <i x-show="mobileOpen" x-cloak class="fas fa-xmark text-lg"></i>
          </button>
        </div>
      </div>
    </div>

    {# Mobile menu #}
    <div x-show="mobileOpen" x-cloak
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      class="sm:hidden border-t border-navy-800 bg-navy-900">
      <div class="pt-2 pb-3 px-4 space-y-1">
        {% block mobile_nav %}{% endblock %}
      </div>
      <div class="pt-3 pb-3 px-4 border-t border-navy-800">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 bg-eco-500 rounded-full flex items-center justify-center text-white text-xs font-bold">
            {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
          </div>
          <div>
            <div class="text-sm font-medium text-white">{{ app.user.fullName }}</div>
            <div class="text-xs text-white/50">{{ app.user.email }}</div>
          </div>
        </div>
        <a href="{{ path('app_logout') }}" class="block px-3 py-2 rounded-md text-sm text-white/70 hover:bg-navy-800 hover:text-white">
          <i class="fas fa-arrow-right-from-bracket mr-2"></i>Déconnexion
        </a>
      </div>
    </div>
  </nav>

  {# ── Page header ─────────────────────────────────────────────────────────── #}
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
      <div>
        <h2 class="text-xl font-bold text-navy-900 leading-tight">{% block page_title %}{% endblock %}</h2>
        {% block page_subtitle %}{% endblock %}
      </div>
      <div class="flex items-center gap-2">
        {% block header_actions %}{% endblock %}
      </div>
    </div>
  </header>

  {# ── Main content ────────────────────────────────────────────────────────── #}
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {% block content %}{% endblock %}
  </main>
</div>
{% endblock %}
