{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen bg-gray-100">

  {# ── Top Navigation (Laravel-style) ─────────────────────────────────────── #}
  <nav class="bg-white border-b border-gray-200" x-data="{ mobileOpen: false, userOpen: false }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">

        {# Left: Logo + Desktop nav #}
        <div class="flex">
          {# Logo #}
          <div class="flex-shrink-0 flex items-center">
            <span class="text-xl mr-2">🚗</span>
            <span class="font-display font-bold text-dark-900 text-lg">EcoFast</span>
            <span class="text-dark-300 text-sm ml-1.5 hidden sm:inline">Hotel</span>
          </div>

          {# Desktop navigation links #}
          <div class="hidden sm:ml-8 sm:flex sm:space-x-1">
            {% block nav_links %}{% endblock %}
          </div>
        </div>

        {# Right: User dropdown #}
        <div class="hidden sm:ml-6 sm:flex sm:items-center">
          <div class="relative" @click.away="userOpen = false">
            <button @click="userOpen = !userOpen"
              class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium text-dark-600 hover:text-dark-900 hover:bg-gray-50 transition-colors">
              <div class="w-8 h-8 bg-dark-900 rounded-full flex items-center justify-center text-white text-xs font-semibold">
                {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
              </div>
              <span>{{ app.user.fullName }}</span>
              <svg class="w-4 h-4 text-dark-400 transition-transform duration-150" :class="userOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div x-show="userOpen" x-cloak
              x-transition:enter="transition ease-out duration-100"
              x-transition:enter-start="opacity-0 scale-95"
              x-transition:enter-end="opacity-100 scale-100"
              x-transition:leave="transition ease-in duration-75"
              x-transition:leave-start="opacity-100 scale-100"
              x-transition:leave-end="opacity-0 scale-95"
              class="absolute right-0 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black/5 z-50">
              <div class="py-1">
                <div class="px-4 py-2 border-b border-gray-100">
                  <div class="text-xs text-dark-400">
                    {% if 'ROLE_ADMIN' in app.user.roles %}Administrateur
                    {% elseif 'ROLE_HOTEL' in app.user.roles %}Hôtel
                    {% elseif 'ROLE_DRIVER' in app.user.roles %}Chauffeur
                    {% endif %}
                  </div>
                  <div class="text-sm font-medium text-dark-900 truncate">{{ app.user.email }}</div>
                </div>
                <a href="{{ path('app_logout') }}" class="block px-4 py-2 text-sm text-dark-600 hover:bg-gray-50 hover:text-dark-900">Déconnexion</a>
              </div>
            </div>
          </div>
        </div>

        {# Mobile hamburger #}
        <div class="flex items-center sm:hidden">
          <button @click="mobileOpen = !mobileOpen" class="p-2 rounded-md text-dark-400 hover:text-dark-600 hover:bg-gray-100">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path x-show="!mobileOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              <path x-show="mobileOpen" x-cloak stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    {# Mobile menu #}
    <div x-show="mobileOpen" x-cloak
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      class="sm:hidden border-t border-gray-200">
      <div class="pt-2 pb-3 px-4 space-y-1">
        {% block mobile_nav %}{% endblock %}
      </div>
      <div class="pt-3 pb-3 px-4 border-t border-gray-200">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 bg-dark-900 rounded-full flex items-center justify-center text-white text-xs font-semibold">
            {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
          </div>
          <div>
            <div class="text-sm font-medium text-dark-900">{{ app.user.fullName }}</div>
            <div class="text-xs text-dark-400">{{ app.user.email }}</div>
          </div>
        </div>
        <a href="{{ path('app_logout') }}" class="block px-3 py-2 rounded-md text-sm text-dark-600 hover:bg-gray-50">Déconnexion</a>
      </div>
    </div>
  </nav>

  {# ── Page header ──────────────────────────────────────────────────────────── #}
  <header class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
      <div>
        <h2 class="text-xl font-semibold text-dark-900 leading-tight">{% block page_title %}{% endblock %}</h2>
        {% block page_subtitle %}{% endblock %}
      </div>
      <div class="flex items-center gap-2">
        {% block header_actions %}{% endblock %}
      </div>
    </div>
  </header>

  {# ── Main content ─────────────────────────────────────────────────────────── #}
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {% block content %}{% endblock %}
  </main>
</div>
{% endblock %}
