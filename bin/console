#!/usr/bin/env php
<?php

use App\Kernel;
use Symfony\Bundle\FrameworkBundle\Console\Application;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Dotenv\Dotenv;

require_once dirname(__DIR__).'/vendor/autoload.php';

// Charge .env sans écraser les variables déjà définies par l'OS / Railway
if (class_exists(Dotenv::class)) {
    (new Dotenv())->bootEnv(dirname(__DIR__).'/.env');
}

$input = new ArgvInput();
$env   = $input->getParameterOption(['--env', '-e'], $_SERVER['APP_ENV'] ?? $_ENV['APP_ENV'] ?? 'prod', true);
$debug = !$input->hasParameterOption('--no-debug', true)
    && filter_var($_SERVER['APP_DEBUG'] ?? $_ENV['APP_DEBUG'] ?? 'prod' !== $env, FILTER_VALIDATE_BOOLEAN);

$kernel      = new Kernel($env, $debug);
$application = new Application($kernel);
$application->run($input);
